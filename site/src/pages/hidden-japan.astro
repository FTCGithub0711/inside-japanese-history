---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import TravelAffiliateBox from '../components/TravelAffiliateBox.astro';
import { SITE } from '../consts';
import { bookingSearch, googleMapsSearch, klookSearch } from '../data/monetization';

const PUB_DATE = '2026-05-05';
const destinations = [
  {
    name: 'Odawara Castle',
    description:
      'A strong first bridge between Sengoku history and travel: castles, Hojo power, and Toyotomi Hideyoshi in one visit.',
    placeHref: googleMapsSearch('Odawara Castle'),
    stayHref: bookingSearch('Odawara, Kanagawa, Japan'),
    activityHref: klookSearch('Odawara Castle Japan'),
  },
  {
    name: 'Sekigahara Battlefield',
    description:
      'Best for readers who want to understand Tokugawa Ieyasu, battlefield geography, and the political end of the Sengoku period.',
    placeHref: googleMapsSearch('Sekigahara Battlefield'),
    stayHref: bookingSearch('Sekigahara, Gifu, Japan'),
    activityHref: klookSearch('Sekigahara battlefield'),
  },
  {
    name: 'Hachigata Castle ruins',
    description:
      'A lesser-known castle site that fits the project well: regional history, terrain, siege warfare, and a quieter travel angle.',
    placeHref: googleMapsSearch('Hachigata Castle ruins'),
    stayHref: bookingSearch('Yorii, Saitama, Japan'),
  },
];
---

<BaseLayout
  title="Hidden Historic Places in Japan"
  description="Lesser-known castles, battlefields, museums, and historic towns in Japan for travelers who want to avoid overtourism and go beyond the obvious route."
  type="article"
>
  <ArticleSchema
    slot="head"
    headline="Hidden Historic Places in Japan"
    description="Lesser-known castles, battlefields, museums, and historic towns in Japan for travelers who want to avoid overtourism and go beyond the obvious route."
    datePublished={PUB_DATE}
  />

  <section class="category-hero">
    <p class="kicker">Hidden Japan Travel</p>
    <h1>Historic places in Japan chosen for what they reveal.</h1>
    <p class="dek">
      This is not a list of random hidden gems. These are castles,
      battlefields, castle towns, museums, and communities where Japanese
      history is still visible if you know what to look for.
    </p>
    <div class="category-hero__meta">
      <span>Beyond the obvious route</span>
      <span>History-led travel</span>
      <span>Affiliate-ready later</span>
    </div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark">
      <strong>歴史旅</strong>
      <span>Travel with context</span>
    </div>
    <div class="category-feature__body">
      <p class="kicker">The rule for this section</p>
      <h2>Understand what you are looking at before booking anything.</h2>
      <p>
        A castle ruin, battlefield, or local museum should not become travel
        content just because it is quiet. It belongs here only when the place
        changes how a reader understands Japan: regional power, memory, roads,
        religious life, local museums, or landscapes shaped by conflict.
      </p>
    </div>
  </section>

  <section class="category-questions">
    <h2>What belongs here</h2>
    <div class="question-grid">
      <article class="question-card">
        <p class="label">Places</p>
        <h3>Less-crowded historic sites</h3>
        <p>Accessible places that are not reduced to the usual Golden Route checklist.</p>
      </article>
      <article class="question-card">
        <p class="label">Castles</p>
        <h3>Beyond the postcard keep</h3>
        <p>Ruins, earthworks, clan territories, siege sites, and the terrain around them.</p>
      </article>
      <article class="question-card">
        <p class="label">Memory</p>
        <h3>Local museums and regional stories</h3>
        <p>Small exhibitions and local records that rarely appear in English travel summaries.</p>
      </article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={destinations}
    title="Starter destinations beyond the obvious route"
    intro="These are examples of how hidden-history travel articles can connect context, maps, nearby stays, and tours without becoming generic sightseeing content."
  />

  <section class="category-note">
    <p>
    Many readers first arrive through samurai, Shōgun, castles, or Japan travel
    searches. This section serves the readers who are not satisfied with the
    same famous stops, but also do not want random hidden-gem lists with no
    historical judgment.
    </p>
  </section>

  <NewsletterCTA />
</BaseLayout>
