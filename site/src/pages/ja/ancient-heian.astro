---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-08';
const travelDestinations = [
  {
    name: '奈良',
    description: '古代国家、仏教、都、制度を現地で考えやすい入口です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Nara%20Japan%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Nara%2C%20Japan',
  },
  {
    name: '飛鳥',
    description: '仏教受容、宮都、古墳、古代政治をコンパクトに歩ける場所です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Asuka%20Nara%20Japan',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Asuka%2C%20Nara%2C%20Japan',
  },
  {
    name: '京都',
    description: '平安京、貴族文化、寺社、文学の記憶を考える入口になります。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Heian%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
];
---

<BaseLayout
  title="原始〜平安"
  description="縄文、弥生、古墳、飛鳥、奈良、平安。武士の時代より前に、日本がどのように形づくられたのかを読む入口です。"
  type="article"
  lang="ja"
>
  <ArticleSchema
    slot="head"
    headline="原始〜平安"
    description="縄文、弥生、古墳、飛鳥、奈良、平安。武士の時代より前に、日本がどのように形づくられたのかを読む入口です。"
    datePublished={PUB_DATE}
    inLanguage="ja"
  />

  <section class="category-hero">
    <p class="kicker">Origins to Heian</p>
    <h1>武士の物語の前に、日本はすでに形を取りはじめていた。</h1>
    <p class="dek">
      縄文、弥生、古墳、飛鳥、奈良、平安。集落、稲作、古墳、文字、仏教、都、貴族文化から、日本史の土台を読みます。
    </p>
    <div class="category-hero__meta"><span>縄文から平安</span><span>国家形成</span><span>信仰</span><span>宮廷文化</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>平安</strong><span>Before the warrior age</span></div>
    <div class="category-feature__body">
      <p class="kicker">読み方</p>
      <h2>古代を、静かな前置きとして扱わない。</h2>
      <p>天皇、都、寺社、氏族、律令、貴族文化。後の時代で当たり前に見える枠組みが、どのように作られたのかを追います。</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>ここで扱うこと</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">原始</p><h3>縄文から弥生で何が変わったのか</h3><p>暮らし、食、集落、稲作、社会の差を考えます。</p></article>
      <article class="question-card"><p class="label">国家</p><h3>古代国家はどう形づくられたのか</h3><p>飛鳥、奈良、古墳、仏教、律令から読みます。</p></article>
      <article class="question-card"><p class="label">文化</p><h3>なぜ平安は古典日本のイメージを作ったのか</h3><p>京都、宮廷、文学、儀礼、美意識の長い影響を見ます。</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="ja"
    title="原始〜平安を歩いて考える場所"
    intro="奈良、飛鳥、京都は、古代国家、仏教、都、平安文化を現地で考える入口になります。"
  />
</BaseLayout>

