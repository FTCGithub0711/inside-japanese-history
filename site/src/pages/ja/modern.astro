---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-06';
const travelDestinations = [
  {
    name: '東京',
    description: '江戸から東京へ。国家づくり、復興、現代都市が重なって見える場所です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Tokyo%20Station%20Imperial%20Palace',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Tokyo%2C%20Japan',
  },
  {
    name: '広島',
    description: '戦争の記憶、復興、平和教育を考えるうえで避けて通れない場所です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Hiroshima%20Peace%20Memorial%20Museum',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Hiroshima%2C%20Japan',
  },
  {
    name: '横浜',
    description: '条約港、鉄道、国際化、都市文化。近代日本の入口として読みやすい町です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Yokohama%20Japan%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Yokohama%2C%20Japan',
  },
];
---

<BaseLayout
  title="近代・現代"
  description="明治から現代まで、国家づくり、戦争、占領、復興、暮らしの変化をたどります。"
  type="article"
  lang="ja"
>
  <ArticleSchema
    slot="head"
    headline="近代・現代"
    description="明治から現代まで、国家づくり、戦争、占領、復興、暮らしの変化をたどります。"
    datePublished={PUB_DATE}
    inLanguage="ja"
  />

  <section class="category-hero">
    <p class="kicker">Modern Japan</p>
    <h1>明治から今日まで、日本は何を変えたのか。</h1>
    <p class="dek">
      明治維新、帝国、戦争、占領、復興、経済成長。近代日本は、制度だけでなく、暮らし方や記憶の変化としても残っています。
    </p>
    <div class="category-hero__meta"><span>明治から現代</span><span>国家づくり</span><span>戦争の記憶</span><span>日常</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>明治</strong><span>Meiji and after</span></div>
    <div class="category-feature__body">
      <p class="kicker">読み方</p>
      <h2>現代の習慣を、すぐ「武士道」に戻さない。</h2>
      <p>現代日本の習慣には、古い制度、近代国家、戦後社会、後から作られた物語が重なっています。</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>ここで扱うこと</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">明治</p><h3>近代化は何を変えたのか</h3><p>制度、身分、教育、軍事、生活の変化を見ます。</p></article>
      <article class="question-card"><p class="label">記憶</p><h3>戦争と占領をどう読むか</h3><p>博物館、都市、記念碑を急いで消費しない視点を作ります。</p></article>
      <article class="question-card"><p class="label">日常</p><h3>現代日本の空気はどこから来たのか</h3><p>礼儀、謝罪、時間感覚、職場文化を歴史から考えます。</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="ja"
    title="近代・現代を歩いて考える場所"
    intro="東京、広島、横浜は、近代化や戦後復興を抽象論ではなく場所として考える入口になります。"
  />
</BaseLayout>
