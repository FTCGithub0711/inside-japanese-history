---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-06';
const travelDestinations = [
  {
    name: '下田',
    description: '黒船と条約の記憶が残る、開国を現地で考えやすい町です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Shimoda%20Japan%20Perry%20Road',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Shimoda%2C%20Shizuoka%2C%20Japan',
  },
  {
    name: '京都の幕末史跡',
    description: '新選組、朝廷、諸藩の動きが重なった幕末政治の中心地です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Shinsengumi%20Mibu-dera',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
  {
    name: '鹿児島',
    description: '薩摩と西郷隆盛を通じて、明治国家への流れを考えられます。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Saigo%20Takamori%20Kagoshima',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kagoshima%2C%20Japan',
  },
];
---

<BaseLayout
  title="幕末"
  description="黒船、開国、尊王攘夷、新選組、内戦、明治維新を、単純な近代化物語にせず読みます。"
  type="article"
  lang="ja"
>
  <ArticleSchema
    slot="head"
    headline="幕末"
    description="黒船、開国、尊王攘夷、新選組、内戦、明治維新を、単純な近代化物語にせず読みます。"
    datePublished={PUB_DATE}
    inLanguage="ja"
  />

  <p class="kicker">Bakumatsu</p>
  <h1>幕末は、きれいな近代化の物語ではない。</h1>

  <p class="dek">
    開国、尊王攘夷、新選組、薩長、内戦、明治維新。幕末は、いくつもの立場と記憶がぶつかった時代です。
  </p>

  <h2>ここで扱うこと</h2>
  <ul>
    <li>なぜ日本は開国へ向かったのか</li>
    <li>坂本龍馬や新選組は、なぜ今も語られるのか</li>
    <li>明治維新の前後で、何が失われ、何が残ったのか</li>
  </ul>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="ja"
    title="幕末を歩いて考える場所"
    intro="条約港、京都の町、薩摩の記憶。現地を歩くと、年表だけでは見えない距離感が出てきます。"
  />
</BaseLayout>
