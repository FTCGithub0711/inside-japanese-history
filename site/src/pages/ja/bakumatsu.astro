---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-06';
const travelDestinations = [
  {
    name: '下田',
    description: '黒船と条約の記憶が残る、開国を現地で考えやすい町です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Shimoda%20Japan%20Perry%20Road',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Shimoda%2C%20Shizuoka%2C%20Japan',
  },
  {
    name: '京都の幕末史跡',
    description: '新選組、朝廷、諸藩の動きが重なった幕末政治の中心地です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Shinsengumi%20Mibu-dera',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
  {
    name: '鹿児島',
    description: '薩摩と西郷隆盛を通じて、明治国家への流れを考えられます。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Saigo%20Takamori%20Kagoshima',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kagoshima%2C%20Japan',
  },
];
---

<BaseLayout
  title="幕末"
  description="黒船、開国、尊王攘夷、新選組、内戦、明治維新を、単純な近代化物語にせず読みます。"
  type="article"
  lang="ja"
>
  <ArticleSchema
    slot="head"
    headline="幕末"
    description="黒船、開国、尊王攘夷、新選組、内戦、明治維新を、単純な近代化物語にせず読みます。"
    datePublished={PUB_DATE}
    inLanguage="ja"
  />

  <section class="category-hero">
    <p class="kicker">Bakumatsu</p>
    <h1>幕末は、きれいな近代化の物語ではない。</h1>
    <p class="dek">
      開国、尊王攘夷、新選組、薩長、内戦、明治維新。幕末は、いくつもの立場と記憶がぶつかった時代です。
    </p>
    <div class="category-hero__meta"><span>1853-1868</span><span>開国</span><span>京都政治</span><span>内戦</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>幕末</strong><span>The curtain falls</span></div>
    <div class="category-feature__body">
      <p class="kicker">読み方</p>
      <h2>開国から明治へ、という一直線では読まない。</h2>
      <p>幕末は、外圧、国内政治、暴力、忠義、利害が重なった時代です。単純な進歩の物語にしないことから始めます。</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>ここで扱うこと</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">外圧</p><h3>なぜ日本は開国へ向かったのか</h3><p>黒船だけでなく、幕府内部の限界も含めて見ます。</p></article>
      <article class="question-card"><p class="label">記憶</p><h3>龍馬や新選組はなぜ語られ続けるのか</h3><p>史実だけでなく、後世の語り方も考えます。</p></article>
      <article class="question-card"><p class="label">現地</p><h3>どこを歩くと幕末が見えるのか</h3><p>下田、京都、鹿児島、会津、萩へつなげます。</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="ja"
    title="幕末を歩いて考える場所"
    intro="条約港、京都の町、薩摩の記憶。現地を歩くと、年表だけでは見えない距離感が出てきます。"
  />
</BaseLayout>
