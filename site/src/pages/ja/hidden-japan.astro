---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';
import { bookingSearch, googleMapsSearch, klookSearch } from '../../data/monetization';

const PUB_DATE = '2026-05-06';
const destinations = [
  {
    name: '小田原城',
    description: '後北条氏の本拠であり、秀吉の小田原攻めを考えるうえでも外せない城です。',
    placeHref: googleMapsSearch('Odawara Castle'),
    stayHref: bookingSearch('Odawara, Kanagawa, Japan'),
    activityHref: klookSearch('Odawara Castle Japan'),
  },
  {
    name: '関ヶ原古戦場',
    description: '徳川家康の勝利だけでなく、地形、布陣、戦後秩序まで見えてくる古戦場です。',
    placeHref: googleMapsSearch('Sekigahara Battlefield'),
    stayHref: bookingSearch('Sekigahara, Gifu, Japan'),
    activityHref: klookSearch('Sekigahara battlefield'),
  },
  {
    name: '鉢形城跡',
    description: '荒川沿いの地形を生かした、後北条氏ゆかりの静かな城跡です。',
    placeHref: googleMapsSearch('Hachigata Castle ruins'),
    stayHref: bookingSearch('Yorii, Saitama, Japan'),
  },
];
---

<BaseLayout
  title="歴史旅"
  description="城跡、古戦場、城下町、地方資料館を、歴史の文脈から訪ねるページです。"
  type="article"
  lang="ja"
>
  <ArticleSchema
    slot="head"
    headline="歴史旅"
    description="城跡、古戦場、城下町、地方資料館を、歴史の文脈から訪ねるページです。"
    datePublished={PUB_DATE}
    inLanguage="ja"
  />

  <section class="category-hero">
    <p class="kicker">Hidden Japan Travel</p>
    <h1>有名観光地の先にある、日本の歴史旅。</h1>
    <p class="dek">
      城跡、古戦場、城下町、地方資料館、宗教遺産。人が少ないからではなく、そこに残る文脈が面白い場所を選びます。
    </p>
    <div class="category-hero__meta"><span>定番ルートの先へ</span><span>歴史から選ぶ旅</span><span>個別記事へ展開</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>歴史旅</strong><span>Travel with context</span></div>
    <div class="category-feature__body">
      <p class="kicker">編集方針</p>
      <h2>ただの穴場紹介では終わらせない。</h2>
      <p>写真を撮って終わる場所ではなく、地形、町割り、展示、石碑、その土地に残る記憶から、歴史の見え方が変わる場所を扱います。</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>扱う場所の考え方</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">史跡</p><h3>混雑しにくい歴史の場所</h3><p>定番ルートから少し外れていても、歴史を読む手がかりが残っている場所。</p></article>
      <article class="question-card"><p class="label">地形</p><h3>城と古戦場</h3><p>天守だけでなく、土塁、堀、山、川、街道、城下町まで含めて見る。</p></article>
      <article class="question-card"><p class="label">記憶</p><h3>地方資料館と地域の話</h3><p>大きな博物館には出にくい地域の記憶を、日本語の資料から拾います。</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={destinations}
    lang="ja"
    title="最初に扱う候補地"
    intro="まずは、歴史の意味と現地での見方が結びつきやすい場所から取り上げます。"
  />

  <h2>読み方</h2>
  <p>
    入口記事では全体像を示し、個別記事では一つの場所を深く扱います。
    たとえば小田原城なら、後北条氏の歴史、城内で見るべき場所、歩き方、食事、宿泊までまとめます。
  </p>

  <NewsletterCTA />
</BaseLayout>
