---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-06';
const travelDestinations = [
  {
    name: '小田原城',
    description: '後北条氏の本拠。秀吉の小田原攻めを考えるうえでも重要な城です。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Odawara%20Castle',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Odawara%2C%20Kanagawa%2C%20Japan',
  },
  {
    name: '関ヶ原古戦場',
    description: '徳川家康の勝利だけでなく、布陣と地形から戦後の秩序まで見えてきます。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Sekigahara%20Battlefield',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Sekigahara%2C%20Gifu%2C%20Japan',
  },
  {
    name: '安土城跡',
    description: '建物は残っていませんが、信長の権力の見せ方を考えるには欠かせません。',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Azuchi%20Castle%20Ruins',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Omihachiman%2C%20Shiga%2C%20Japan',
  },
];
---

<BaseLayout
  title="戦国"
  description="信長、秀吉、家康だけでなく、城、合戦、鉄砲、忍者、地域権力から戦国を読みます。"
  type="article"
  lang="ja"
>
  <ArticleSchema
    slot="head"
    headline="戦国"
    description="信長、秀吉、家康だけでなく、城、合戦、鉄砲、忍者、地域権力から戦国を読みます。"
    datePublished={PUB_DATE}
    inLanguage="ja"
  />

  <p class="kicker">Sengoku</p>
  <h1>戦国を、人物だけで終わらせない。</h1>

  <p class="dek">
    信長、秀吉、家康はもちろん重要です。ただ、戦国の面白さは、城の構え、土地の形、同盟、裏切り、地域ごとの判断にもあります。
  </p>

  <h2>ここで扱うこと</h2>
  <ul>
    <li>戦国時代は、なぜ長く続いたのか</li>
    <li>信長、秀吉、家康は何を変えたのか</li>
    <li>城と地形は、合戦をどう左右したのか</li>
    <li>武士、忍者、鉄砲のイメージは、どこまで史実なのか</li>
  </ul>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="ja"
    title="戦国を歩いて考える場所"
    intro="城や古戦場は、名前を知るだけでは見えてきません。現地で地形や距離を見ると、理解が変わります。"
  />
</BaseLayout>
