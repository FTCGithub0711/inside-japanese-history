---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import TravelAffiliateBox from '../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-04';
const travelDestinations = [
  {
    name: 'Odawara Castle',
    description: 'A major castle site for understanding the Hōjō, Toyotomi Hideyoshi, and the final stage of Sengoku unification.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Odawara%20Castle',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Odawara%2C%20Kanagawa%2C%20Japan',
  },
  {
    name: 'Sekigahara Battlefield',
    description: 'The battlefield most closely tied to Tokugawa Ieyasu and the political end of the Sengoku period.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Sekigahara%20Battlefield',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Sekigahara%2C%20Gifu%2C%20Japan',
  },
  {
    name: 'Azuchi Castle ruins',
    description: 'A strong travel link for Oda Nobunaga, castle innovation, and the transition toward national unification.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Azuchi%20Castle%20Ruins',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Omihachiman%2C%20Shiga%2C%20Japan',
  },
];
---

<BaseLayout
  title="The Sengoku Period: Japan's Century of War"
  description="A pillar guide to Japan's Sengoku period (1467–1603) — the warlords, the sieges, the unification, and the end of the samurai world's first chapter."
  type="article"
>
  <ArticleSchema
    slot="head"
    headline="The Sengoku Period: Japan's Century of War"
    description="A pillar guide to Japan's Sengoku period (1467–1603) — the warlords, the sieges, the unification, and the end of the samurai world's first chapter."
    datePublished={PUB_DATE}
  />

  <section class="category-hero">
    <p class="kicker">Sengoku</p>
    <h1>The century when Japan had no single center.</h1>
    <p class="dek">
      The Sengoku period is not just a parade of warlords. It is the story of
      castles, roads, guns, river valleys, hostages, marriages, betrayals, and
      the long pressure that finally produced Tokugawa rule.
    </p>
    <div class="category-hero__meta">
      <span>1467-1603</span>
      <span>Castles</span>
      <span>Battlefields</span>
      <span>Unification</span>
    </div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark">
      <strong>戦国</strong>
      <span>Age of Warring States</span>
    </div>
    <div class="category-feature__body">
      <p class="kicker">How to read this period</p>
      <h2>Start with Nobunaga if you want. But do not stop there.</h2>
      <p>
        Nobunaga, Hideyoshi, and Ieyasu matter because they changed the shape
        of power. This archive follows the material side of that change: where
        castles stood, why firearms mattered, how terrain shaped decisions, and
        how regional families survived until they could not.
      </p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Questions this archive will answer</h2>
    <div class="question-grid">
      <article class="question-card">
        <p class="label">Power</p>
        <h3>What did unification actually mean?</h3>
        <p>Beyond “three great unifiers,” the period was a slow reordering of land, loyalty, and violence.</p>
      </article>
      <article class="question-card">
        <p class="label">Warfare</p>
        <h3>Did samurai really fight the way pop culture imagines?</h3>
        <p>Guns, ashigaru, sieges, logistics, and terrain complicate the sword-centered image.</p>
      </article>
      <article class="question-card">
        <p class="label">Places</p>
        <h3>Where can you still see Sengoku history on the ground?</h3>
        <p>Odawara, Sekigahara, Azuchi, Hachigata, and other sites make the period visible.</p>
      </article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    title="Sengoku places to understand the period"
    intro="For readers planning a history-focused trip, these places connect directly to major Sengoku castles, battlefields, and warlords."
  />
</BaseLayout>
