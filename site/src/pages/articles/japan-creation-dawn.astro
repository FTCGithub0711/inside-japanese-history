  .article-photo {
    margin: 2rem 0;
  }

  .article-photo img {
    aspect-ratio: 16 / 9;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    display: block;
    height: auto;
    object-fit: cover;
    width: 100%;
  }
</style>
