---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import TravelAffiliateBox from '../components/TravelAffiliateBox.astro';
const PUB_DATE = '2026-05-04';
const travelDestinations = [
  {
    name: 'Shimoda',
    description: 'A key place for Perry, treaty-port history, and the opening of Japan.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Shimoda%20Japan%20Perry%20Road',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Shimoda%2C%20Shizuoka%2C%20Japan',
  },
  {
    name: 'Kyoto Bakumatsu sites',
    description: 'The strongest base for Shinsengumi, imperial court politics, and late Tokugawa conflict.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Shinsengumi%20Mibu-dera',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
  {
    name: 'Kagoshima',
    description: 'A useful route into Satsuma, Saigō Takamori, and the forces that reshaped Meiji Japan.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Saigo%20Takamori%20Kagoshima',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kagoshima%2C%20Japan',
  },
];
---

<BaseLayout
  title="Bakumatsu: The End of the Samurai Era"
  description="A pillar guide to Bakumatsu (1853–1868) — Japan's collision with the West, the fall of the Tokugawa shogunate, and the men who chose between worlds."
  type="article"
>
  <ArticleSchema
    slot="head"
    headline="Bakumatsu: The End of the Samurai Era"
    description="A pillar guide to Bakumatsu (1853–1868) — Japan's collision with the West, the fall of the Tokugawa shogunate, and the men who chose between worlds."
    datePublished={PUB_DATE}
  />

  <section class="category-hero">
    <p class="kicker">Bakumatsu</p>
    <h1>The end of the shogunate was not a clean beginning.</h1>
    <p class="dek">
      Black ships, treaty ports, Kyoto violence, imperial politics, civil war,
      and the Meiji Restoration all crowd into a few volatile years. Bakumatsu
      is where the old order cracked before modern Japan had a stable shape.
    </p>
    <div class="category-hero__meta">
      <span>1853-1868</span>
      <span>Treaty ports</span>
      <span>Kyoto politics</span>
      <span>Civil war</span>
    </div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark">
      <strong>幕末</strong>
      <span>The curtain falls</span>
    </div>
    <div class="category-feature__body">
      <p class="kicker">How to read this period</p>
      <h2>Do not turn Bakumatsu into a simple modernization story.</h2>
      <p>
        The period is often told as Japan opening to the West and racing toward
        progress. That is too neat. This archive keeps the pressure visible:
        unequal treaties, domestic fear, factional violence, loyalists,
        opportunists, and people trying to survive a collapsing system.
      </p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Questions this archive will answer</h2>
    <div class="question-grid">
      <article class="question-card">
        <p class="label">Pressure</p>
        <h3>Why did the Black Ships matter so much?</h3>
        <p>Perry did not simply “open Japan.” He exposed weaknesses already building inside Tokugawa rule.</p>
      </article>
      <article class="question-card">
        <p class="label">Memory</p>
        <h3>Why do Ryōma, Shinsengumi, and Saigō still matter?</h3>
        <p>Their afterlives reveal how modern Japan keeps retelling the end of the samurai order.</p>
      </article>
      <article class="question-card">
        <p class="label">Places</p>
        <h3>Where can you walk the transition?</h3>
        <p>Shimoda, Kyoto, Kagoshima, Aizu, and Hagi each show a different side of the collapse.</p>
      </article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    title="Bakumatsu places to understand the transition"
    intro="For readers planning a history-focused trip, these places connect the late shogunate with treaty ports, Kyoto conflict, and Satsuma history."
  />
</BaseLayout>
