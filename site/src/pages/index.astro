---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import PersonSchema from '../components/PersonSchema.astro';
import PodcastSchema from '../components/PodcastSchema.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { SITE } from '../consts';
import { localizedHref, siteTemplate, t } from '../copy/siteTemplate';

const armorImage = 'https://commons.wikimedia.org/wiki/Special:FilePath/SamuraiArmor.jpg?width=900';
const ieyasuImage = 'https://commons.wikimedia.org/wiki/Special:FilePath/Tokugawa%20Ieyasu.jpg?width=900';
const castleImage = SITE.heroImages[0].src;
const waveImage = SITE.heroImages[3].src;
const locale = 'en';
---

<BaseLayout
  title={t(siteTemplate.home.meta.title, locale)}
  description={t(siteTemplate.home.meta.description, locale)}
>
  <PersonSchema slot="head" person="both" />
  <PodcastSchema slot="head" />

  <HeroSlideshow
    kicker={t(siteTemplate.home.hero.kicker, locale)}
    title={t(siteTemplate.home.hero.title, locale)}
    description={t(siteTemplate.home.hero.description, locale)}
    primaryLabel={t(siteTemplate.home.hero.primaryLabel, locale)}
    primaryHref={SITE.substackUrl}
    secondaryLabel={t(siteTemplate.home.hero.secondaryLabel, locale)}
    secondaryHref="#topics"
  />

  <div class="trust-strip">
    {siteTemplate.home.trustStrip.map((item) => (
      <p><strong>{t(item.strong, locale)}</strong>{t(item.text, locale)}</p>
    ))}
  </div>

  <section class="home-intro" aria-label="Editorial introduction">
    <p class="kicker">For readers who want the story beneath the itinerary</p>
    <h2>Japan is easy to photograph. It is harder to read.</h2>
    <p>
      This site follows the places, documents, debates, and local memory that
      make Japanese history visible: castle towns, battlefields, family lines,
      political collapse, religious communities, and the stories that travel
      articles often compress.
    </p>
  </section>

  <section class="feature-showcase" aria-label="Featured feature">
    <img src={castleImage} alt="Hojō Ujikuni statue beneath cherry blossoms" loading="lazy" />
    <div>
      <p class="kicker">First feature in progress</p>
      <h2>Hidden historic places in Japan, chosen for what they reveal.</h2>
      <p>
        Odawara, Sekigahara, Azuchi, Aizu-Wakamatsu, Hagi, Nagasaki, and
        Hachigata are not just quieter alternatives to the usual route. Each
        place preserves a turning point you can still walk.
      </p>
      <a class="text-link" href={localizedHref('/hidden-japan/', locale)}>Explore history-led travel</a>
    </div>
  </section>

  <section class="editorial-map refined">
    <div>
      <p class="kicker">{t(siteTemplate.home.direction.kicker, locale)}</p>
      <h2>{t(siteTemplate.home.direction.title, locale)}</h2>
    </div>
    <p>{t(siteTemplate.home.direction.text, locale)}</p>
  </section>

  <section class="home-section" aria-labelledby="starting-points">
    <div class="section-heading">
      <p class="kicker">Start with a question</p>
      <h2 id="starting-points">Popular entry points, rebuilt from Japanese context.</h2>
    </div>
    <div class="feature-grid elevated">
      <article class="feature-card">
      <img src={armorImage} alt="Samurai armor displayed at the British Museum" loading="lazy" />
      <div class="body">
        <p class="label">Samurai Myths</p>
        <h3>The samurai stories English pop culture keeps simplifying</h3>
        <p>
          Weapons, bushido, seppuku, loyalty, firearms, and the gap between
          battlefield history and later romantic images.
        </p>
      </div>
    </article>
    <div class="feature-list">
      <article class="mini-feature">
        <img src={ieyasuImage} alt="Portrait of Tokugawa Ieyasu" loading="lazy" />
        <div>
          <p class="label">Shōgun & Real History</p>
          <h3>The real politics behind Toranaga</h3>
          <p>Tokugawa Ieyasu, Sekigahara, and what drama compresses.</p>
        </div>
      </article>
      <article class="mini-feature">
        <img src={waveImage} alt="The Great Wave off Kanagawa" loading="lazy" />
        <div>
          <p class="label">Modern Japan</p>
          <h3>How Japan changed without becoming simple</h3>
          <p>Meiji, empire, defeat, recovery, memory, and everyday modernity.</p>
        </div>
      </article>
    </div>
    </div>
  </section>

  <section class="home-section" id="topics" aria-labelledby="topic-heading">
    <div class="section-heading">
      <p class="kicker">Read by route</p>
      <h2 id="topic-heading">{t(siteTemplate.home.topicIntro.heading, locale)}</h2>
      <p>{t(siteTemplate.home.topicIntro.text, locale)}</p>
    </div>
    <div class="pillar-grid polished">
      {siteTemplate.home.pillars.map((pillar) => (
        <div class="pillar-card">
          <h3><a href={localizedHref(pillar.href, locale)}>{t(pillar.title, locale)}</a></h3>
          <p>{t(pillar.text, locale)}</p>
        </div>
      ))}
      <div class="pillar-card">
        <h3>Shōgun & Real History</h3>
        <p>Character inspirations, historical accuracy, Tokugawa politics, and what drama compresses.</p>
      </div>
      <div class="pillar-card">
        <h3>Samurai Myths</h3>
        <p>Katana myths, bushido, seppuku, firearms, ninja, and the stories English pop culture repeats.</p>
      </div>
      <div class="pillar-card">
        <h3>Castles & Battlefields</h3>
        <p>Odawara, Sekigahara, Himeji, Azuchi, terrain, siege warfare, and what survives on the ground.</p>
      </div>
    </div>
  </section>

  <section class="editorial-principles" aria-label="Editorial principles">
    <div>
      <p class="kicker">Editorial standard</p>
      <h2>Clear enough to enter. Serious enough to trust.</h2>
    </div>
    <ol>
      <li>
        <strong>Begin with the question readers already have.</strong>
        <span>Shōgun, samurai, castles, ninja, Meiji, travel, and the familiar myths that bring people in.</span>
      </li>
      <li>
        <strong>Return to Japanese sources and places.</strong>
        <span>Books, museums, local records, official materials, maps, and what remains on the ground.</span>
      </li>
      <li>
        <strong>Turn the context into a readable journey.</strong>
        <span>No mystery for mystery’s sake. No shallow checklist. Just the story made visible.</span>
      </li>
    </ol>
  </section>

  <NewsletterCTA variant="compact" />

  <SocialLinks />
</BaseLayout>
