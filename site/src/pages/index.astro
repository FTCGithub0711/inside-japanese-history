---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import PersonSchema from '../components/PersonSchema.astro';
import PodcastSchema from '../components/PodcastSchema.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { SITE } from '../consts';
import { localizedHref, siteTemplate, t } from '../copy/siteTemplate';

const armorImage = 'https://commons.wikimedia.org/wiki/Special:FilePath/SamuraiArmor.jpg?width=900';
const ieyasuImage = 'https://commons.wikimedia.org/wiki/Special:FilePath/Tokugawa%20Ieyasu.jpg?width=900';
const castleImage = SITE.heroImages[0].src;
const locale = 'en';
---

<BaseLayout
  title={t(siteTemplate.home.meta.title, locale)}
  description={t(siteTemplate.home.meta.description, locale)}
>
  <PersonSchema slot="head" person="both" />
  <PodcastSchema slot="head" />

  <HeroSlideshow
    kicker={t(siteTemplate.home.hero.kicker, locale)}
    title={t(siteTemplate.home.hero.title, locale)}
    description={t(siteTemplate.home.hero.description, locale)}
    primaryLabel={t(siteTemplate.home.hero.primaryLabel, locale)}
    primaryHref={SITE.substackUrl}
    secondaryLabel={t(siteTemplate.home.hero.secondaryLabel, locale)}
    secondaryHref="#topics"
  />

  <div class="trust-strip">
    {siteTemplate.home.trustStrip.map((item) => (
      <p><strong>{t(item.strong, locale)}</strong>{t(item.text, locale)}</p>
    ))}
  </div>

  <section class="authority-note" aria-label="Editorial authority">
    <p class="kicker">{t(siteTemplate.home.authority.kicker, locale)}</p>
    <h2>{t(siteTemplate.home.authority.title, locale)}</h2>
    <p>{t(siteTemplate.home.authority.text, locale)}</p>
  </section>

  <NewsletterCTA variant="compact" />

  <section class="editorial-map">
    <div>
      <p class="kicker">{t(siteTemplate.home.direction.kicker, locale)}</p>
      <h2>{t(siteTemplate.home.direction.title, locale)}</h2>
    </div>
    <p>{t(siteTemplate.home.direction.text, locale)}</p>
  </section>

  <h2>Featured starting points</h2>
  <div class="feature-grid">
    <article class="feature-card">
      <img src={armorImage} alt="Samurai armor displayed at the British Museum" loading="lazy" />
      <div class="body">
        <p class="label">Samurai Myths</p>
        <h3>Did samurai really live by the myths English pop culture repeats?</h3>
        <p>
          Start with weapons, bushido, seppuku, and the gap between battlefield
          history and later romantic images.
        </p>
      </div>
    </article>
    <div class="feature-list">
      <article class="mini-feature">
        <img src={ieyasuImage} alt="Portrait of Tokugawa Ieyasu" loading="lazy" />
        <div>
          <p class="label">Shōgun & Real History</p>
          <h3>The real politics behind Toranaga</h3>
          <p>Tokugawa Ieyasu, Sekigahara, and what drama compresses.</p>
        </div>
      </article>
      <article class="mini-feature">
        <img src={castleImage} alt="Himeji Castle keep seen from the grounds" loading="lazy" />
        <div>
          <p class="label">Castles & Battlefields</p>
          <h3>How terrain shaped Japanese warfare</h3>
          <p>Castles, sieges, river valleys, and what survives today.</p>
        </div>
      </article>
    </div>
  </div>

  <h2 id="topics">{t(siteTemplate.home.topicIntro.heading, locale)}</h2>
  <p>{t(siteTemplate.home.topicIntro.text, locale)}</p>
  <div class="pillar-grid">
    {siteTemplate.home.pillars.map((pillar) => (
      <div class="pillar-card">
        <h3><a href={localizedHref(pillar.href, locale)}>{t(pillar.title, locale)}</a></h3>
        <p>{t(pillar.text, locale)}</p>
      </div>
    ))}
    <div class="pillar-card">
      <h3>Shōgun & Real History</h3>
      <p>Character inspirations, historical accuracy, Tokugawa politics, and what the drama simplifies.</p>
    </div>
    <div class="pillar-card">
      <h3>Samurai Myths</h3>
      <p>Katana myths, bushido, seppuku, firearms, ninja, and the stories English pop culture repeats.</p>
    </div>
    <div class="pillar-card">
      <h3>Castles & Battlefields</h3>
      <p>Odawara, Sekigahara, Himeji, Azuchi, terrain, siege warfare, and what survives on the ground.</p>
    </div>
  </div>

  <h2>Editorial tracks</h2>
  <div class="topic-rank">
    <div>
      <p class="label">Track 1</p>
      <h3>High-demand gateways</h3>
      <p>Is Shōgun a true story? Were ninja real? Did samurai use guns? These are the questions that bring readers in.</p>
    </div>
    <div>
      <p class="label">Track 2</p>
      <h3>Japanese source depth</h3>
      <p>Each piece is checked against Japanese-language historians, source collections, and period-specific debates.</p>
    </div>
    <div>
      <p class="label">Track 3</p>
      <h3>Hidden Japan travel</h3>
      <p>Lesser-known castles, battlefield geography, local museums, and quieter routes where affiliate links can be useful after the context is clear.</p>
    </div>
  </div>

  <h2>Why this exists</h2>
  <p>
    Japanese history online is often filtered through outside summaries, pop
    culture, and familiar Western categories. That can make the story easy to
    enter, but it also flattens the Japanese context.
  </p>
  <p>
    This project adds another angle: <strong>Japanese historical judgment,
    edited into clear prose.</strong> The point is not to make Japan seem
    mysterious. The point is to make the context visible.
  </p>

  <div class="note-box">
    <p>
      The site can move from Sengoku to Bakumatsu to modern Japan because each
      section answers a different reader question. The connection is not strict
      chronology; it is how Japan's past still shapes what readers notice today.
    </p>
  </div>

  <SocialLinks />
</BaseLayout>
