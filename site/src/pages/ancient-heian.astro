---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import TravelAffiliateBox from '../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-08';
const travelDestinations = [
  {
    name: 'Nara',
    description: 'A strong base for early state formation, Buddhism, imperial capitals, and the institutions that shaped classical Japan.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Nara%20Japan%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Nara%2C%20Japan',
  },
  {
    name: 'Asuka',
    description: 'A compact landscape for early Buddhism, court politics, burial mounds, and the roots of Japan as a state.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Asuka%20Nara%20Japan',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Asuka%2C%20Nara%2C%20Japan',
  },
  {
    name: 'Kyoto',
    description: 'The most accessible entry into Heian court culture, aristocratic memory, temples, shrines, and later reinterpretations.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Heian%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
];
---

<BaseLayout
  title="Origins to Heian: How Japan Became Japan"
  description="Early Japanese history as a readable story of rice, Himiko, Yamatai, kofun, Buddhism, Nara, Heian, and the road to samurai power."
  type="article"
>
  <ArticleSchema
    slot="head"
    headline="Origins to Heian: How Japan Became Japan"
    description="Early Japanese history as a readable story of rice, Himiko, Yamatai, kofun, Buddhism, Nara, Heian, and the road to samurai power."
    datePublished={PUB_DATE}
  />

  <section class="category-hero">
    <p class="kicker">Origins to Heian</p>
    <h1>Before the samurai, Japan was already a political drama.</h1>
    <p class="dek">
      This is the archive for the stranger beginning: rice that created
      hierarchy, a queen seen through Chinese records, tombs that turned power
      into landscape, Buddhism as statecraft, and a courtly world that slowly
      made warriors necessary.
    </p>
    <div class="category-hero__meta">
      <span>Jōmon to Heian</span>
      <span>Himiko & Yamatai</span>
      <span>Kofun power</span>
      <span>Road to samurai</span>
    </div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark">
      <strong>平安</strong>
      <span>Before the warrior age</span>
    </div>
    <div class="category-feature__body">
      <p class="kicker">How to read this period</p>
      <h2>Do not start Japanese history only when swords appear.</h2>
      <p>
        The categories later readers take for granted, emperor, capital, shrine,
        temple, clan, court, and province, were assembled through conflict,
        borrowing, ritual, and political reinvention. This section reads that
        formation as a story, not a glossary.
      </p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Start with the strongest question</h2>
    <div class="question-grid">
      <article class="question-card">
        <p class="label">Featured pillar</p>
        <h3><a href="/articles/japan-creation-dawn/">How Japan Became Japan</a></h3>
        <p>
          A dramatic entry point for readers who know samurai and castles, but
          not the queen, tombs, monks, coups, and capital politics that came first.
        </p>
      </article>
      <article class="question-card">
        <p class="label">Coming next</p>
        <h3>Was Himiko the shadow at the beginning?</h3>
        <p>
          The Yamatai debate is not just a map puzzle. It changes how the first
          political center of Japan feels.
        </p>
      </article>
      <article class="question-card">
        <p class="label">Coming next</p>
        <h3>Why build a grave larger than a village?</h3>
        <p>
          Kofun were not only burials. They were ancient political theater, and
          they still shape the landscape.
        </p>
      </article>
    </div>
  </section>

  <section class="category-questions">
    <h2>Questions this archive will keep returning to</h2>
    <div class="question-grid">
      <article class="question-card">
        <p class="label">Power</p>
        <h3>When does a village become a state?</h3>
        <p>Food, water, surplus, hierarchy, ritual, and coercion turn daily life into politics.</p>
      </article>
      <article class="question-card">
        <p class="label">Belief</p>
        <h3>Why did Buddhism become politically explosive?</h3>
        <p>Temples were not only sacred places. They carried writing, prestige, architecture, and state technology.</p>
      </article>
      <article class="question-card">
        <p class="label">Warriors</p>
        <h3>How did court elegance produce armed men?</h3>
        <p>Heian culture was refined, but land disputes and private estates made protection unavoidable.</p>
      </article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    title="Places to begin early Japanese history"
    intro="These places connect early state formation, Buddhist institutions, capitals, and Heian court culture with routes travelers can actually follow."
  />
</BaseLayout>
