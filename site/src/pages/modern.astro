---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import TravelAffiliateBox from '../components/TravelAffiliateBox.astro';
const PUB_DATE = '2026-05-04';
const travelDestinations = [
  {
    name: 'Tokyo',
    description: 'The center for Meiji state-building, imperial institutions, postwar reconstruction, and modern urban Japan.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Tokyo%20Station%20Imperial%20Palace',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Tokyo%2C%20Japan',
  },
  {
    name: 'Hiroshima',
    description: 'A necessary destination for modern Japanese history, war memory, reconstruction, and peace education.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Hiroshima%20Peace%20Memorial%20Museum',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Hiroshima%2C%20Japan',
  },
  {
    name: 'Yokohama',
    description: 'A clear travel link for treaty-port history, Meiji internationalization, railways, and modern urban culture.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Yokohama%20Japan%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Yokohama%2C%20Japan',
  },
];
---

<BaseLayout
  title="Modern Japan: Meiji to Today"
  description="How samurai-era values quietly shape modern Japan — punctuality, shame culture, work ethic, and the quiet logic of contemporary Japanese life."
  type="article"
>
  <ArticleSchema
    slot="head"
    headline="Modern Japan: Meiji to Today"
    description="How samurai-era values quietly shape modern Japan — punctuality, shame culture, work ethic, and the quiet logic of contemporary Japanese life."
    datePublished={PUB_DATE}
  />

  <section class="category-hero">
    <p class="kicker">Modern Japan</p>
    <h1>Modern Japan did not begin by becoming simple.</h1>
    <p class="dek">
      Meiji reform, empire, war, defeat, occupation, recovery, and daily habits
      all belong in the same conversation. This archive asks what changed, what
      survived, and what later stories made too neat.
    </p>
    <div class="category-hero__meta">
      <span>Meiji to today</span>
      <span>State-building</span>
      <span>War memory</span>
      <span>Everyday life</span>
    </div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark">
      <strong>明治</strong>
      <span>Meiji and after</span>
    </div>
    <div class="category-feature__body">
      <p class="kicker">How to read this period</p>
      <h2>Modern habits are not proof that “samurai values” simply survived.</h2>
      <p>
        Punctuality, bowing, apology, restraint, work culture, and social
        pressure are real things travelers notice. But easy explanations can
        flatten history. This archive separates older institutions, modern
        state-building, postwar change, and later nostalgia.
      </p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Questions this archive will answer</h2>
    <div class="question-grid">
      <article class="question-card">
        <p class="label">Meiji</p>
        <h3>What did modernization actually change?</h3>
        <p>The state remade institutions, status, education, military power, and everyday expectations.</p>
      </article>
      <article class="question-card">
        <p class="label">Memory</p>
        <h3>How should visitors read war and recovery?</h3>
        <p>Hiroshima, Tokyo, museums, and monuments ask for more than quick symbolic answers.</p>
      </article>
      <article class="question-card">
        <p class="label">Everyday life</p>
        <h3>Where do modern Japanese habits come from?</h3>
        <p>Some are old, some are modern, and some are stories Japan later told about itself.</p>
      </article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    title="Modern Japan places to understand the era"
    intro="For readers planning a history-focused trip, these cities connect modern Japanese history with state-building, war memory, reconstruction, and everyday urban life."
  />
</BaseLayout>
