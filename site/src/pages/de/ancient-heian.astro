---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-08';
const travelDestinations = [
  {
    name: 'Nara',
    description: 'Ein guter Einstieg in frühe Staatsbildung, Buddhismus, Hauptstädte und Institutionen.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Nara%20Japan%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Nara%2C%20Japan',
  },
  {
    name: 'Asuka',
    description: 'Ein kompakter Ort für frühen Buddhismus, Hofpolitik, Grabhügel und Staatsbildung.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Asuka%20Nara%20Japan',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Asuka%2C%20Nara%2C%20Japan',
  },
  {
    name: 'Kyoto',
    description: 'Der zugänglichste Einstieg in Heian-Hofkultur, Tempel, Schreine und aristokratische Erinnerung.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Heian%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
];
---

<BaseLayout
  title="Ursprünge bis Heian"
  description="Frühe japanische Geschichte von Jōmon, Yayoi, Kofun, Asuka und Nara bis Heian: Gemeinschaften, Staat, Religion und Hofkultur."
  type="article"
  lang="de"
>
  <ArticleSchema
    slot="head"
    headline="Ursprünge bis Heian"
    description="Frühe japanische Geschichte von Jōmon, Yayoi, Kofun, Asuka und Nara bis Heian: Gemeinschaften, Staat, Religion und Hofkultur."
    datePublished={PUB_DATE}
    inLanguage="de"
  />

  <section class="category-hero">
    <p class="kicker">Ursprünge bis Heian</p>
    <h1>Bevor die Samurai-Erzählung beginnt, nimmt Japan bereits Gestalt an.</h1>
    <p class="dek">
      Siedlungen, Reisanbau, Grabhügel, Schrift, Buddhismus, Hauptstädte,
      Hofrang und Literatur bilden den langen Anfang japanischer Geschichte.
    </p>
    <div class="category-hero__meta"><span>Jōmon bis Heian</span><span>Staatsbildung</span><span>Religion</span><span>Hofkultur</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>平安</strong><span>Before the warrior age</span></div>
    <div class="category-feature__body">
      <p class="kicker">Lesart</p>
      <h2>Frühes Japan ist keine ruhige Vorgeschichte.</h2>
      <p>Kaiser, Hauptstadt, Tempel, Schreine, Clan, Hof und Provinz wurden über lange Zeit zusammengefügt.</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Kernfragen in diesem Archiv</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">Ursprünge</p><h3>Was änderte sich von Jōmon zu Yayoi?</h3><p>Ernährung, Siedlung, Landwirtschaft, Ritual und soziale Unterschiede verändern die früheste Geschichte.</p></article>
      <article class="question-card"><p class="label">Staat</p><h3>Wie entstand Hofregierung?</h3><p>Asuka und Nara machen importierte Institutionen in Recht, Tempeln, Hauptstädten und Gräbern sichtbar.</p></article>
      <article class="question-card"><p class="label">Kultur</p><h3>Warum prägt Heian das Bild des klassischen Japan?</h3><p>Kyoto, Hofrang, Literatur, Ritual und Ästhetik wirken lange nach.</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="de"
    title="Orte für den Einstieg in frühe japanische Geschichte"
    intro="Diese Orte verbinden Staatsbildung, Buddhismus, Hauptstädte und Heian-Hofkultur mit realen Reiserouten."
  />
</BaseLayout>

