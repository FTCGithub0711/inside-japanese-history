---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-04';
const travelDestinations = [
  {
    name: 'Odawara Castle',
    description: 'Ein wichtiger Ort für Hōjō-Geschichte, Toyotomi Hideyoshi und die letzte Phase der Reichseinigung.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Odawara%20Castle',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Odawara%2C%20Kanagawa%2C%20Japan',
  },
  {
    name: 'Sekigahara Battlefield',
    description: 'Der wichtigste Bezugspunkt für Tokugawa Ieyasu und das politische Ende der Sengoku-Zeit.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Sekigahara%20Battlefield',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Sekigahara%2C%20Gifu%2C%20Japan',
  },
  {
    name: 'Azuchi Castle ruins',
    description: 'Ein guter Ort für Oda Nobunaga, Burgeninnovation und den Übergang zur Reichseinigung.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Azuchi%20Castle%20Ruins',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Omihachiman%2C%20Shiga%2C%20Japan',
  },
];
---

<BaseLayout
  title="Die Sengoku-Zeit: Japans Jahrhundert der Kriege"
  description="Ein Einstieg in die Sengoku-Zeit (1467-1603): Kriegsherren, Burgen, Belagerungen, Reichseinigung und der Weg zu Tokugawa Ieyasu."
  type="article"
  lang="de"
>
  <ArticleSchema
    slot="head"
    headline="Die Sengoku-Zeit: Japans Jahrhundert der Kriege"
    description="Ein Einstieg in die Sengoku-Zeit (1467-1603): Kriegsherren, Burgen, Belagerungen, Reichseinigung und der Weg zu Tokugawa Ieyasu."
    datePublished={PUB_DATE}
    inLanguage="de"
  />

  <section class="category-hero">
    <p class="kicker">Sengoku</p>
    <h1>Das Jahrhundert, in dem Japan kein einzelnes Zentrum hatte.</h1>
    <p class="dek">
      Sengoku ist mehr als eine Reihe berühmter Kriegsherren. Es geht um Burgen,
      Straßen, Feuerwaffen, Täler, Geiseln, Ehen, Verrat und den langen Druck,
      der schließlich Tokugawa-Herrschaft möglich machte.
    </p>
    <div class="category-hero__meta"><span>1467-1603</span><span>Burgen</span><span>Schlachtfelder</span><span>Reichseinigung</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>戦国</strong><span>Age of Warring States</span></div>
    <div class="category-feature__body">
      <p class="kicker">Lesart</p>
      <h2>Beginnen Sie mit Nobunaga. Aber bleiben Sie nicht dort stehen.</h2>
      <p>Dieses Archiv folgt der materiellen Seite der Macht: Burgen, Gelände, Feuerwaffen, regionale Familien und die Wege zur Tokugawa-Ordnung.</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Kernfragen in diesem Archiv</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">Macht</p><h3>Was bedeutete Reichseinigung konkret?</h3><p>Nicht nur drei große Einiger, sondern eine Neuordnung von Land, Loyalität und Gewalt.</p></article>
      <article class="question-card"><p class="label">Krieg</p><h3>Kämpften Samurai wirklich wie in der Popkultur?</h3><p>Feuerwaffen, Fußsoldaten, Belagerungen und Gelände verändern das Bild.</p></article>
      <article class="question-card"><p class="label">Orte</p><h3>Wo sieht man Sengoku noch vor Ort?</h3><p>Odawara, Sekigahara, Azuchi und Hachigata machen diese Zeit greifbar.</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="de"
    title="Sengoku-Orte, die diese Epoche verständlicher machen"
    intro="Für eine geschichtsorientierte Reise verbinden diese Orte wichtige Sengoku-Burgen, Schlachtfelder und Kriegsherren."
  />
</BaseLayout>
