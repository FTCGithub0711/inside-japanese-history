---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSlideshow from '../../components/HeroSlideshow.astro';
import PersonSchema from '../../components/PersonSchema.astro';
import { SITE } from '../../consts';
import { localizedHref, siteTemplate, t } from '../../copy/siteTemplate';

const armorImage = 'https://commons.wikimedia.org/wiki/Special:FilePath/SamuraiArmor.jpg?width=900';
const ieyasuImage = 'https://commons.wikimedia.org/wiki/Special:FilePath/Tokugawa%20Ieyasu.jpg?width=900';
const castleImage = SITE.heroImages[0].src;
const locale = 'de';
---

<BaseLayout
  title={t(siteTemplate.home.meta.title, locale)}
  description={t(siteTemplate.home.meta.description, locale)}
  lang="de"
>
  <PersonSchema slot="head" person="both" />

  <HeroSlideshow
    kicker={t(siteTemplate.home.hero.kicker, locale)}
    title={t(siteTemplate.home.hero.title, locale)}
    description={t(siteTemplate.home.hero.description, locale)}
    primaryLabel={t(siteTemplate.home.hero.primaryLabel, locale)}
    primaryHref={SITE.substackUrl}
    secondaryLabel={t(siteTemplate.home.hero.secondaryLabel, locale)}
    secondaryHref="#themen"
  />

  <div class="trust-strip">
    {siteTemplate.home.trustStrip.map((item) => (
      <p><strong>{t(item.strong, locale)}</strong>{t(item.text, locale)}</p>
    ))}
  </div>

  <section class="authority-note" aria-label="Redaktionelle Autorität">
    <p class="kicker">{t(siteTemplate.home.authority.kicker, locale)}</p>
    <h2>{t(siteTemplate.home.authority.title, locale)}</h2>
    <p>{t(siteTemplate.home.authority.text, locale)}</p>
  </section>

  <section class="editorial-map">
    <div>
      <p class="kicker">{t(siteTemplate.home.direction.kicker, locale)}</p>
      <h2>{t(siteTemplate.home.direction.title, locale)}</h2>
    </div>
    <p>{t(siteTemplate.home.direction.text, locale)}</p>
  </section>

  <h2>Einstiegspunkte</h2>
  <p>
    Diese Seite konzentriert sich vorerst auf drei starke Routen: Sengoku,
    Bakumatsu und weniger bekannte historische Orte. Diese Themen verbinden
    Suchinteresse, erzählerische Spannung und reale Reiseplanung am besten.
  </p>

  <div class="feature-grid">
    <article class="feature-card">
      <img src={armorImage} alt="Samurai-Rüstung in einem Museum" loading="lazy" />
      <div class="body">
        <p class="label">Sengoku</p>
        <h3>Kriegsherren, Burgen, Waffen und Schlachtfeldgeografie</h3>
        <p>
          Nobunaga, Hideyoshi, Ieyasu, Odawara, Sekigahara, Azuchi, Ninja,
          Feuerwaffen und die Mythen, die Leser sofort suchen.
        </p>
      </div>
    </article>
    <div class="feature-list">
      <article class="mini-feature">
        <img src={ieyasuImage} alt="Porträt von Tokugawa Ieyasu" loading="lazy" />
        <div>
          <p class="label">Bakumatsu</p>
          <h3>Als die alte Ordnung sichtbar zerbrach</h3>
          <p>Schwarze Schiffe, Shinsengumi, Ryōma, Aizu, Satsuma, Chōshū, Bürgerkrieg und Restauration.</p>
        </div>
      </article>
      <article class="mini-feature">
        <img src={castleImage} alt="Bergfried von Himeji Castle" loading="lazy" />
        <div>
          <p class="label">Hidden Places</p>
          <h3>Historische Reisen jenseits der Standardroute</h3>
          <p>Burgruinen, Schlachtfeldstädte, lokale Museen, alte Straßen und ruhigere Routen mit stärkeren Geschichten.</p>
        </div>
      </article>
    </div>
  </div>

  <h2 id="themen">{t(siteTemplate.home.topicIntro.heading, locale)}</h2>
  <p>{t(siteTemplate.home.topicIntro.text, locale)}</p>
  <div class="pillar-grid">
    {siteTemplate.home.pillars.map((pillar) => (
      <div class="pillar-card">
        <h3><a href={localizedHref(pillar.href, locale)}>{t(pillar.title, locale)}</a></h3>
        <p>{t(pillar.text, locale)}</p>
      </div>
    ))}
  </div>

  <h2>Redaktionelle Spuren</h2>
  <div class="topic-rank">
    <div>
      <p class="label">Spur 1</p>
      <h3>Starke Einstiegsthemen</h3>
      <p>Sengoku, Bakumatsu, Burgen, Samurai, Shinsengumi und Hidden Places bringen neue Leser auf die Seite.</p>
    </div>
    <div>
      <p class="label">Spur 2</p>
      <h3>Japanische Grundlage</h3>
      <p>Die Argumente werden mit japanischen Historikern, Quellen und Fachdebatten geprüft.</p>
    </div>
    <div>
      <p class="label">Spur 3</p>
      <h3>Hidden Places</h3>
      <p>Weniger bekannte Burgen, Schlachtfeldgeografie, lokale Museen und ruhigere Routen mit sinnvollen Links erst nach dem Kontext.</p>
    </div>
  </div>
</BaseLayout>
