---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-04';
const travelDestinations = [
  {
    name: 'Shimoda',
    description: 'Ein zentraler Ort für Perry, Vertragshäfen und die Öffnung Japans.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Shimoda%20Japan%20Perry%20Road',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Shimoda%2C%20Shizuoka%2C%20Japan',
  },
  {
    name: 'Kyoto und Shinsengumi-Orte',
    description: 'Die stärkste Basis für Shinsengumi, Hofpolitik und Konflikte der späten Tokugawa-Zeit.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Kyoto%20Shinsengumi%20Mibu-dera',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kyoto%2C%20Japan',
  },
  {
    name: 'Kagoshima',
    description: 'Ein guter Einstieg in Satsuma, Saigō Takamori und die Kräfte hinter Meiji.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Saigo%20Takamori%20Kagoshima',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Kagoshima%2C%20Japan',
  },
];
---

<BaseLayout
  title="Bakumatsu: Das Ende der Samurai-Ära"
  description="Ein Einstieg in Bakumatsu (1853-1868): Schwarze Schiffe, Tokugawa-Shogunat, Meiji-Restauration und Japans Entscheidung zwischen Welten."
  type="article"
  lang="de"
>
  <ArticleSchema
    slot="head"
    headline="Bakumatsu: Das Ende der Samurai-Ära"
    description="Ein Einstieg in Bakumatsu (1853-1868): Schwarze Schiffe, Tokugawa-Shogunat, Meiji-Restauration und Japans Entscheidung zwischen Welten."
    datePublished={PUB_DATE}
    inLanguage="de"
  />

  <section class="category-hero">
    <p class="kicker">Bakumatsu</p>
    <h1>Das Ende des Shogunats war kein sauberer Neubeginn.</h1>
    <p class="dek">
      Schwarze Schiffe, Vertragshäfen, Gewalt in Kyoto, Hofpolitik,
      Bürgerkrieg und Meiji-Restauration drängen sich in wenige unruhige Jahre.
    </p>
    <div class="category-hero__meta"><span>1853-1868</span><span>Vertragshäfen</span><span>Kyoto</span><span>Bürgerkrieg</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>幕末</strong><span>The curtain falls</span></div>
    <div class="category-feature__body">
      <p class="kicker">Lesart</p>
      <h2>Bakumatsu ist keine einfache Geschichte von Modernisierung.</h2>
      <p>Dieses Archiv hält den Druck sichtbar: ungleiche Verträge, innere Angst, politische Gewalt, Loyalität und Menschen in einem zerfallenden System.</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Kernfragen in diesem Archiv</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">Druck</p><h3>Warum waren die Schwarzen Schiffe so wichtig?</h3><p>Perry öffnete Japan nicht einfach; er machte innere Schwächen sichtbar.</p></article>
      <article class="question-card"><p class="label">Erinnerung</p><h3>Warum bleiben Ryōma und Shinsengumi so präsent?</h3><p>Ihre Nachleben zeigen, wie Japan das Ende der Samurai-Ordnung erzählt.</p></article>
      <article class="question-card"><p class="label">Orte</p><h3>Wo kann man den Übergang gehen?</h3><p>Shimoda, Kyoto, Kagoshima, Aizu und Hagi zeigen unterschiedliche Seiten.</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="de"
    title="Bakumatsu-Orte, die den Übergang verständlicher machen"
    intro="Für eine geschichtsorientierte Reise verbinden diese Orte die späte Tokugawa-Politik mit Vertragshäfen, Kyoto-Konflikten und Satsuma-Geschichte."
  />
</BaseLayout>
