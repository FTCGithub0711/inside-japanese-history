---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';
import { bookingSearch, googleMapsSearch, klookSearch } from '../../data/monetization';

const PUB_DATE = '2026-05-05';
const destinations = [
  {
    name: 'Burg Odawara',
    description:
      'Ein guter Einstieg in Sengoku-Geschichte vor Ort: Burgen, Hojo-Macht und Toyotomi Hideyoshi in einem Reiseziel.',
    placeHref: googleMapsSearch('Odawara Castle'),
    stayHref: bookingSearch('Odawara, Kanagawa, Japan'),
    activityHref: klookSearch('Odawara Castle Japan'),
  },
  {
    name: 'Schlachtfeld Sekigahara',
    description:
      'Passend fuer Leser, die Tokugawa Ieyasu, Gelaende und das politische Ende der Sengoku-Zeit verstehen wollen.',
    placeHref: googleMapsSearch('Sekigahara Battlefield'),
    stayHref: bookingSearch('Sekigahara, Gifu, Japan'),
    activityHref: klookSearch('Sekigahara battlefield'),
  },
  {
    name: 'Burgruine Hachigata',
    description:
      'Ein weniger bekannter Ort mit regionaler Geschichte, Gelaende, Belagerung und ruhigerem Reiseprofil.',
    placeHref: googleMapsSearch('Hachigata Castle ruins'),
    stayHref: bookingSearch('Yorii, Saitama, Japan'),
  },
];
---

<BaseLayout
  title="Hidden Historic Places in Japan"
  description="Weniger bekannte Burgen, Schlachtfelder, Museen und historische Orte in Japan fuer Reisende, die Overtourism vermeiden und tiefer reisen wollen."
  type="article"
  lang="de-DE"
>
  <ArticleSchema
    slot="head"
    headline="Hidden Historic Places in Japan"
    description="Weniger bekannte Burgen, Schlachtfelder, Museen und historische Orte in Japan fuer Reisende, die Overtourism vermeiden und tiefer reisen wollen."
    datePublished={PUB_DATE}
    inLanguage="de-DE"
  />

  <section class="category-hero">
    <p class="kicker">Hidden Japan Travel</p>
    <h1>Historische Orte in Japan, ausgewählt nach dem, was sie sichtbar machen.</h1>
    <p class="dek">
      Keine zufällige Liste von Hidden Gems: Burgen, Schlachtfelder,
      Burgstädte, Museen und Gemeinschaften, an denen japanische Geschichte
      noch lesbar ist.
    </p>
    <div class="category-hero__meta"><span>Jenseits der Standardroute</span><span>Reisen mit Kontext</span><span>Später mit Buchungslinks</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>歴史旅</strong><span>Travel with context</span></div>
    <div class="category-feature__body">
      <p class="kicker">Redaktioneller Ansatz</p>
      <h2>Erst verstehen, was man sieht. Dann planen.</h2>
      <p>Ein Ort gehört hierher, wenn er erklärt, wie regionale Macht, Erinnerung, Wege, Religion oder Landschaft Japans Geschichte sichtbar machen.</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Was hierher gehört</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">Orte</p><h3>Weniger überlaufene historische Orte</h3><p>Erreichbare Orte außerhalb der üblichen Golden Route.</p></article>
      <article class="question-card"><p class="label">Burgen</p><h3>Jenseits der Postkarte</h3><p>Ruinen, Erdwerke, Clan-Gebiete, Belagerungsorte und Gelände.</p></article>
      <article class="question-card"><p class="label">Erinnerung</p><h3>Lokale Museen und regionale Geschichten</h3><p>Kleine Ausstellungen und lokale Quellen, die selten in Reisetexten erscheinen.</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={destinations}
    title="Erste Ziele jenseits der offensichtlichen Route"
    intro="Diese Beispiele zeigen, wie Hidden-Japan-Artikel Kontext, Karten, Unterkuenfte und Tourlinks verbinden koennen, ohne allgemeine Reisetexte zu werden."
    lang="de"
  />

  <NewsletterCTA />
</BaseLayout>
