---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TravelAffiliateBox from '../../components/TravelAffiliateBox.astro';

const PUB_DATE = '2026-05-04';
const travelDestinations = [
  {
    name: 'Tokyo',
    description: 'Zentrum von Meiji-Staatsbildung, kaiserlichen Institutionen, Wiederaufbau und modernem Stadtleben.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Tokyo%20Station%20Imperial%20Palace',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Tokyo%2C%20Japan',
  },
  {
    name: 'Hiroshima',
    description: 'Ein wichtiger Ort für Kriegserinnerung, Wiederaufbau und Friedenserziehung.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Hiroshima%20Peace%20Memorial%20Museum',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Hiroshima%2C%20Japan',
  },
  {
    name: 'Yokohama',
    description: 'Ein klarer Bezugspunkt für Vertragshäfen, Meiji-Internationalisierung und moderne Stadtkultur.',
    placeHref: 'https://www.google.com/maps/search/?api=1&query=Yokohama%20Japan%20history',
    stayHref: 'https://www.booking.com/searchresults.html?ss=Yokohama%2C%20Japan',
  },
];
---

<BaseLayout
  title="Modernes Japan: Von Meiji bis heute"
  description="Wie ältere Werte aus Samurai- und Frühmoderne bis heute modernes Japan prägen: Pünktlichkeit, Schamkultur, Arbeitsethos und Alltag."
  type="article"
  lang="de"
>
  <ArticleSchema
    slot="head"
    headline="Modernes Japan: Von Meiji bis heute"
    description="Wie ältere Werte aus Samurai- und Frühmoderne bis heute modernes Japan prägen: Pünktlichkeit, Schamkultur, Arbeitsethos und Alltag."
    datePublished={PUB_DATE}
    inLanguage="de"
  />

  <section class="category-hero">
    <p class="kicker">Modernes Japan</p>
    <h1>Modernes Japan begann nicht dadurch, einfach zu werden.</h1>
    <p class="dek">
      Meiji-Reformen, Kaiserreich, Krieg, Niederlage, Besatzung, Wiederaufbau
      und Alltag gehören in dieselbe Diskussion.
    </p>
    <div class="category-hero__meta"><span>Meiji bis heute</span><span>Staat</span><span>Kriegserinnerung</span><span>Alltag</span></div>
  </section>

  <section class="category-feature">
    <div class="category-feature__mark"><strong>明治</strong><span>Meiji and after</span></div>
    <div class="category-feature__body">
      <p class="kicker">Lesart</p>
      <h2>Moderne Gewohnheiten sind nicht einfach überlebte Samurai-Werte.</h2>
      <p>Dieses Archiv trennt ältere Institutionen, modernen Staat, Nachkriegswandel und spätere Nostalgie.</p>
    </div>
  </section>

  <section class="category-questions">
    <h2>Kernfragen in diesem Archiv</h2>
    <div class="question-grid">
      <article class="question-card"><p class="label">Meiji</p><h3>Was veränderte Modernisierung wirklich?</h3><p>Institutionen, Status, Bildung, Militär und Alltag wurden neu geordnet.</p></article>
      <article class="question-card"><p class="label">Erinnerung</p><h3>Wie liest man Krieg und Wiederaufbau?</h3><p>Hiroshima, Tokyo, Museen und Denkmäler brauchen mehr als schnelle Symbole.</p></article>
      <article class="question-card"><p class="label">Alltag</p><h3>Woher kommen moderne japanische Gewohnheiten?</h3><p>Manches ist alt, manches modern, manches eine spätere Erzählung.</p></article>
    </div>
  </section>

  <TravelAffiliateBox
    destinations={travelDestinations}
    lang="de"
    title="Orte, die modernes Japan verständlicher machen"
    intro="Für eine geschichtsorientierte Reise verbinden diese Städte moderne japanische Geschichte mit Staat, Kriegserinnerung, Wiederaufbau und Alltag."
  />
</BaseLayout>
