---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import TravelAffiliateBox from '../../../components/TravelAffiliateBox.astro';
import { bookingSearch, googleMapsSearch, klookSearch } from '../../../data/monetization';
import { existsSync, readdirSync } from 'node:fs';
import { resolve } from 'node:path';

const imageDir = resolve(process.cwd(), 'public/images/articles/japan-creation-dawn');
const imageFiles = existsSync(imageDir)
  ? readdirSync(imageDir)
      .filter((file) => /\.(jpe?g|png|webp)$/i.test(file))
      .sort((a, b) => a.localeCompare(b))
  : [];
const articleImages = imageFiles.map((file) => {
  const label = file
    .replace(/\.[^.]+$/, '')
    .replace(/^\d+[-_\s]*/, '')
    .replace(/[-_]+/g, ' ')
    .trim();

  return {
    src: `/images/articles/japan-creation-dawn/${file}`,
    alt: label ? `Artikelfoto: ${label}` : 'Artikelfoto',
  };
});
const extensionPriority = (src: string) => {
  if (src.endsWith('.webp')) return 0;
  if (src.endsWith('.jpg')) return 1;
  if (src.endsWith('.jpeg')) return 2;
  return 3;
};
const photoByKeyword = (...keywords: string[]) =>
  articleImages
    .filter((image) => keywords.some((keyword) => image.src.toLowerCase().includes(keyword)))
    .sort((a, b) => extensionPriority(a.src) - extensionPriority(b.src))[0];

const toc = [
  { id: 'before-samurai', label: 'Vor der Samurai-Erzaehlung' },
  { id: 'rice', label: 'Reis veraenderte die Gesellschaft' },
  { id: 'himiko', label: 'Himiko und Yamatai' },
  { id: 'kofun', label: 'Kofun und Yamato' },
  { id: 'buddhism', label: 'Buddhismus und Staat' },
  { id: 'taika', label: 'Taika und Ritsuryo' },
  { id: 'nara-heian', label: 'Von Nara nach Heian' },
  { id: 'warriors', label: 'Der Weg zu den Kriegern' },
];

const related = [
  {
    title: 'Urspruenge bis Heian',
    description: 'Die Kategorie fuer fruehe japanische Geschichte vor dem Kriegerzeitalter.',
    href: '/de/ancient-heian/',
    kicker: 'Urspruenge',
  },
  {
    title: 'Sengoku',
    description: 'Nach den Grundlagen fuehrt der Weg zu Burgen, Kriegsherren und Einigung.',
    href: '/de/sengoku/',
    kicker: 'Kriegerzeit',
  },
  {
    title: 'Hidden Spots',
    description: 'Historische Orte fuer Reisende, die mehr suchen als die Standardroute.',
