---
import Analytics from '../components/Analytics.astro';
import { SITE } from '../consts';
import { localeFromLang, localizedHref, siteTemplate, t } from '../copy/siteTemplate';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  lang?: string;
}

const {
  title,
  description = SITE.description,
  image = '/og-default.png',
  type = 'website',
  canonical,
  lang = SITE.language,
} = Astro.props;

const fullTitle = title === SITE.name ? title : title + ' — ' + SITE.name;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const isGerman = lang.startsWith('de');
const isJapanese = lang.startsWith('ja');
const locale = localeFromLang(lang);
const basePath = Astro.url.pathname
  .replace(/^\/de(?=\/|$)/, '')
  .replace(/^\/ja(?=\/|$)/, '') || '/';
const localizedPaths = new Set([
  '/',
  '/about/',
  '/sengoku/',
  '/bakumatsu/',
  '/hidden-japan/',
  '/articles/japan-creation-dawn/',
  '/categories/beginner/',
  '/categories/history/',
  '/categories/people/',
  '/categories/perspective/',
  '/categories/onsite/',
  '/categories/events/',
]);
const withLocale = (prefix: '' | '/de' | '/ja') => {
  const targetPath = localizedPaths.has(basePath) ? basePath : '/';
  if (targetPath === '/') return prefix + '/';
  return prefix + targetPath;
};
const languageLinks = [
  { href: withLocale(''), label: 'English', active: !isGerman && !isJapanese },
  { href: withLocale('/de'), label: 'Deutsch', active: isGerman },
  { href: withLocale('/ja'), label: '日本語', active: isJapanese },
];
const navLinks = Object.values(siteTemplate.header.nav).map((link) => ({
  href: localizedHref(link.href, locale),
  label: t(link, locale),
}));
const subscribeLabel = t(siteTemplate.header.subscribe, locale);
const footerText = t(siteTemplate.footer.text, locale);
const legalLinks = Object.values(siteTemplate.footer.legal).map((link) => ({
  href: link.href,
  label: t(link, locale),
}));
const homeHref = isGerman ? '/de/' : isJapanese ? '/ja/' : '/';
const aboutHref = localizedHref('/about/', locale);
const archiveHref = localizedHref('/categories/history/', locale);
const accessLabel = isJapanese ? '本文へ' : isGerman ? 'Zum Inhalt' : 'Skip to content';
const aboutLabel = isJapanese ? 'このサイト' : isGerman ? 'Ueber' : 'About';
const searchLabel = isJapanese ? '記事一覧' : isGerman ? 'Archiv' : 'Archive';
const sectionsLabel = isJapanese ? '目次' : isGerman ? 'Rubriken' : 'Sections';
const motto = isJapanese
  ? '日本史を、物語と現地の手がかりから読む。'
  : isGerman
    ? 'Japanische Geschichte durch Erzaehlung, Orte und Quellen lesen.'
    : 'Read Japanese history through story, places, and sources.';
const footerAbout = isJapanese ? 'このサイトについて' : isGerman ? 'Ueber diese Seite' : 'About';
const footerSections = isJapanese ? '目次' : isGerman ? 'Rubriken' : 'Sections';
const footerFollow = isJapanese ? 'フォロー' : isGerman ? 'Folgen' : 'Follow';
const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': new URL('/#organization', Astro.site).toString(),
      name: SITE.name,
      url: SITE.url,
      logo: new URL('/og-default.png', Astro.site).toString(),
    },
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).toString(),
      name: SITE.name,
      alternateName: SITE.tagline,
      url: SITE.url,
      inLanguage: SITE.language,
      publisher: { '@id': new URL('/#organization', Astro.site).toString() },
      potentialAction: {
        '@type': 'SearchAction',
        target: new URL('/?q={search_term_string}', Astro.site).toString(),
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
const controlCopy = isJapanese
  ? { modeGroup: '表示モード', modeLabel: '表示', light: '明', dark: '暗', sizeGroup: '文字サイズ', sizeLabel: '文字', medium: '中', large: '大' }
  : isGerman
    ? { modeGroup: 'Anzeigemodus', modeLabel: 'Modus', light: 'Hell', dark: 'Dunkel', sizeGroup: 'Textgroesse', sizeLabel: 'Text', medium: 'M', large: 'G' }
    : { modeGroup: 'Display mode', modeLabel: 'Mode', light: 'Light', dark: 'Dark', sizeGroup: 'Text size', sizeLabel: 'Text', medium: 'M', large: 'L' };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title={SITE.name + ' — Newsletter'} href={SITE.substackUrl + '/feed'} />
    <link rel="alternate" type="application/rss+xml" title={SITE.name + ' — Podcast'} href={SITE.podcastFeedUrl} />
    {languageLinks.map((link) => (
      <link rel="alternate" hreflang={link.label === 'Deutsch' ? 'de' : link.label === '日本語' ? 'ja' : 'en'} href={new URL(link.href, Astro.site).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(withLocale(''), Astro.site).toString()} />
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} />
    <Analytics />
    <script is:inline>
      (() => {
        try {
          const themeKey = 'inside-japanese-history-theme-mode';
          const hour = new Date().getHours();
          const autoTheme = hour >= 18 || hour < 6 ? 'dark' : 'light';
          const theme = localStorage.getItem(themeKey) || autoTheme;
          document.documentElement.classList.toggle('theme-dark', theme === 'dark');
          document.documentElement.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
        } catch (_) {}
      })();
    </script>
    <style is:global>
      :root {
        color-scheme: light;
        --font-headline: "Postoni", "Bodoni 72", "Playfair Display", Georgia, "Times New Roman", serif;
        --font-body: Georgia, "Times New Roman", serif;
        --font-meta: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
        --paper: #ffffff;
        --ink: #111111;
        --muted: #5f5f5f;
        --hairline: #e2e2e2;
        --hairline-strong: #cfcfcf;
        --accent: #d20f1f;
        --footer-muted: #b8b8b8;
        --max-page: 1240px;
        --max-width: 800px;
        --wide-width: 1240px;
        --color-paper: var(--paper);
        --color-surface: var(--paper);
        --color-ink: var(--ink);
        --color-muted: var(--muted);
        --color-accent: var(--accent);
        --color-indigo: #000000;
        --color-gold: var(--accent);
        --color-border: var(--hairline);
      }

      * { box-sizing: border-box; }
      html { background: var(--paper); color: var(--ink); font-family: var(--font-body); scroll-behavior: smooth; }
      html.theme-dark { background: #101010; }
      html[lang^="ja"] { --font-headline: "Hiragino Mincho ProN", "Yu Mincho", YuMincho, "Noto Serif JP", serif; --font-body: "Hiragino Mincho ProN", "Yu Mincho", YuMincho, "Noto Serif JP", serif; --font-meta: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Yu Gothic", Meiryo, sans-serif; }
      body { min-width: 320px; margin: 0; overflow-x: hidden; background: var(--paper); color: var(--ink); font-family: var(--font-meta); font-size: 17px; line-height: 1.62; -webkit-font-smoothing: antialiased; }
      body::before { display: none; }
      a { color: inherit; }
      img { display: block; max-width: 100%; width: 100%; height: auto; }
      figure { margin: 0; }
      figcaption { margin-top: 8px; color: var(--muted); font-family: var(--font-meta); font-size: .75rem; line-height: 1.45; }
      h1, h2, h3, p { margin-top: 0; }
      h1, h2, h3 { color: var(--ink); font-family: var(--font-headline); font-weight: 900; letter-spacing: 0; text-wrap: balance; }
      h1 { margin-bottom: 16px; font-size: clamp(2rem, 4.8vw, 3.7rem); line-height: 1.04; }
      h2 { margin-bottom: 22px; font-size: clamp(1.55rem, 2.5vw, 2.2rem); line-height: 1.1; }
      h3 { margin-bottom: 8px; font-size: 1.22rem; line-height: 1.22; }
      p, li { font-size: 1rem; }

      .utility-row, .logo-row, .section-nav, main, .footer-inner, .footer-bottom { max-width: var(--max-page); margin: 0 auto; }
      main { padding: 0 24px 72px; }
      main > * { min-width: 0; }
      .sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; padding: 0; }

      .masthead { background: var(--paper); border-bottom: 1px solid var(--hairline); }
      .utility-row { display: grid; grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr); grid-template-areas: "left center right"; align-items: center; gap: 12px 18px; padding: 8px 24px; border-bottom: 1px solid var(--hairline); color: var(--muted); font-family: var(--font-meta); font-size: .75rem; font-weight: 750; }
      .utility-left { grid-area: left; justify-content: flex-start; }
      .utility-center { grid-area: center; justify-content: center; }
      .utility-right { grid-area: right; justify-content: flex-end; }
      .utility-left, .utility-center, .utility-right { display: flex; align-items: center; gap: 10px; min-width: 0; }
      .utility-right { flex-wrap: wrap; }
      .utility-row a, .theme-controls button, .reader-controls button, .section-nav a, .lead-story a, .rail-card a, .article-stack a, .path-grid a, .all-news a, .text-link, .site-footer a, .article-nav a, .new-articles-list a, .category-list a { text-decoration: none; }
      .utility-row a:hover, .section-nav a:hover, .text-link:hover, .read-more:hover { color: var(--accent); }

      .language-switcher { display: flex; align-items: center; justify-content: center; gap: 4px; min-width: 0; }
      .language-switcher a { flex: 0 0 auto; min-height: 28px; padding: 5px 8px; border: 1px solid transparent; font-size: .75rem; font-weight: 850; line-height: 1; white-space: nowrap; }
      .language-switcher a.active { border-color: var(--ink); color: var(--ink); background: var(--paper); }
      .theme-controls, .reader-controls { display: inline-flex; align-items: center; gap: 2px; min-height: 28px; padding: 2px; border: 1px solid var(--hairline-strong); color: var(--ink); background: var(--paper); font-family: var(--font-meta); line-height: 1; }
      .theme-controls span, .reader-controls span { padding: 0 6px; color: var(--muted); font-size: .72rem; font-weight: 900; white-space: nowrap; }
      .theme-controls button, .reader-controls button { min-width: 30px; min-height: 24px; padding: 3px 7px; border: 0; border-radius: 0; color: var(--ink); background: transparent; font-family: var(--font-meta); font-size: .75rem; font-weight: 900; line-height: 1; cursor: pointer; }
      .theme-controls button[aria-pressed="true"], .reader-controls button[aria-pressed="true"] { color: var(--paper); background: var(--ink); }
      .menu-button { display: inline-flex; align-items: center; justify-content: center; min-height: 28px; padding: 5px 10px; color: var(--paper); background: var(--ink); border: 1px solid var(--ink); font-family: var(--font-meta); font-size: .75rem; font-weight: 900; line-height: 1; white-space: nowrap; }

      .logo-row { display: grid; place-items: center; gap: 8px; padding: 22px 24px 17px; text-align: center; }
      .gazette-logo { display: block; max-width: 100%; color: var(--ink); line-height: 1; text-decoration: none; }
      .logo-main { display: block; max-width: 100%; font-family: var(--font-headline); font-size: clamp(2.35rem, 5.5vw, 4.6rem); font-weight: 900; line-height: .96; overflow-wrap: anywhere; text-wrap: balance; }
      .logo-sub { display: block; margin-top: 9px; color: var(--ink); font-family: var(--font-meta); font-size: .7rem; font-weight: 850; letter-spacing: .12em; line-height: 1.2; text-transform: uppercase; }
      .site-motto { margin: 0; color: var(--muted); font-family: var(--font-meta); font-size: .78rem; font-weight: 500; line-height: 1.35; text-wrap: balance; }
      .site-motto::before, .site-motto::after { content: ""; display: inline-block; width: 34px; height: 1px; margin: 0 8px 3px; background: var(--hairline); }

      .section-nav { display: flex; justify-content: center; gap: 22px; overflow-x: auto; padding: 0 24px; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); scrollbar-width: none; -webkit-overflow-scrolling: touch; }
      .section-nav::-webkit-scrollbar { display: none; }
      .section-nav a { flex: 0 0 auto; padding: 12px 0 10px; border-bottom: 3px solid transparent; color: var(--ink); font-family: var(--font-meta); font-size: .86rem; font-weight: 850; line-height: 1; white-space: nowrap; }
      .section-nav a:hover, .section-nav a[aria-current="page"] { border-bottom-color: var(--ink); color: var(--ink); }

      .event-callout { display: flex; flex-wrap: wrap; gap: 8px 12px; align-items: baseline; padding: 13px 0; border-bottom: 1px solid var(--hairline); color: var(--muted); font-family: var(--font-meta); font-size: .9rem; line-height: 1.45; }
      .event-callout strong { color: var(--ink); font-weight: 900; }
      .lead-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 318px); gap: 30px; padding: 30px 0 42px; border-bottom: 1px solid var(--hairline); }
      .lead-story { padding-bottom: 30px; border-bottom: 1px solid var(--hairline); }
      .lead-link { display: grid; grid-template-columns: minmax(230px, .82fr) minmax(0, 1.18fr); gap: 30px; align-items: start; color: inherit; }
      .story-text { min-width: 0; }
      .story-text p:not(.kicker), .article-deck, .people-section p { color: var(--muted); font-family: var(--font-meta); font-size: clamp(1rem, 1.4vw, 1.15rem); font-weight: 400; line-height: 1.58; }
      .story-art img, .article-hero img, .article-stack img, .field-grid img, .people-section img, .feature-card img, .mini-feature img { aspect-ratio: 3 / 2; object-fit: cover; background: var(--hairline); }
      .kicker, .section-label, .label { margin: 0 0 8px; color: var(--ink); font-family: var(--font-meta); font-size: .84rem; font-weight: 900; line-height: 1.2; text-transform: none; }
      .section-label { font-size: .95rem; }
      .read-more, .text-link { display: inline-flex; align-items: center; gap: 8px; color: var(--ink); font-family: var(--font-meta); font-size: .95rem; font-weight: 900; line-height: 1.3; }
      .read-more { margin-top: 8px; }
      .read-more::after, .text-link::after { content: "→"; color: var(--accent); font-weight: 900; }

      .right-rail { min-width: 0; padding-left: 22px; border-left: 1px solid var(--hairline); }
      .rail-block + .most-read { margin-top: 30px; }
      .rail-card { border-top: 1px solid var(--hairline); }
      .rail-card a { display: grid; grid-template-columns: 76px minmax(0, 1fr); gap: 12px; align-items: start; padding: 12px 0; color: inherit; }
      .rail-card img { width: 76px; height: 76px; object-fit: cover; }
      .rail-card h3 { margin: 0; font-family: var(--font-meta); font-size: .98rem; line-height: 1.24; }
      .rail-card .kicker { margin-bottom: 4px; font-size: .72rem; }
      .most-read { border-top: 1px solid var(--ink); padding-top: 15px; }
      .most-read ol { margin: 0; padding: 0; list-style: none; counter-reset: most-read; }
      .most-read li { display: grid; grid-template-columns: 32px minmax(0, 1fr); gap: 10px; padding: 12px 0; border-top: 1px solid var(--hairline); counter-increment: most-read; }
      .most-read li::before { content: counter(most-read); color: var(--accent); font-family: var(--font-headline); font-size: 1.75rem; font-weight: 900; line-height: .95; }
      .most-read a { color: inherit; font-family: var(--font-meta); font-size: .95rem; font-weight: 850; line-height: 1.35; }

      .new-articles, .two-column, .start-paths, .news-band, .all-news, .travel-section, .people-section, .home-section, .editorial-principles { padding: 44px 0; border-bottom: 1px solid var(--hairline); }
      .section-heading { position: sticky; top: 20px; align-self: start; max-width: none; }
      .section-heading h2 { margin-top: 0; }
      .new-articles > .section-heading, .news-band > .section-heading { position: static; margin-bottom: 26px; }
      .new-articles-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 30px; margin: 0 0 24px; padding: 0; list-style: none; }
      .new-articles-list li { border-top: 1px solid var(--hairline); }
      .new-articles-list a { display: block; padding: 16px 0 18px; color: inherit; }
      .new-articles-list time, .post-date { display: block; margin-bottom: 6px; color: var(--muted); font-family: var(--font-meta); font-size: .75rem; font-weight: 750; }
      .new-articles-list h3 { margin: 0 0 8px; font-size: clamp(1.2rem, 1.8vw, 1.55rem); }
      .new-articles-list p:not(.kicker) { margin: 0; color: var(--muted); font-family: var(--font-meta); font-size: .98rem; line-height: 1.55; }

      .path-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1px; background: var(--hairline); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
      .path-grid a { position: relative; min-height: 190px; padding: 22px; overflow: hidden; background: var(--paper); color: inherit; }
      .path-grid span { display: block; margin-bottom: 34px; color: var(--hairline-strong); font-family: var(--font-headline); font-size: clamp(2.4rem, 4vw, 3.45rem); font-weight: 900; line-height: .85; }
      .path-grid strong { display: block; margin-bottom: 10px; font-family: var(--font-headline); font-size: clamp(1.2rem, 1.8vw, 1.55rem); font-weight: 900; line-height: 1.16; }
      .path-grid p { margin-bottom: 0; color: var(--muted); font-family: var(--font-meta); font-size: .96rem; line-height: 1.55; }

      .two-column { display: grid; grid-template-columns: minmax(220px, 320px) minmax(0, 1fr); gap: 36px; }
      .article-stack { display: grid; gap: 28px; }
      .article-stack article, .field-grid article { border-top: 1px solid var(--hairline); padding-top: 16px; }
      .article-stack a { display: grid; grid-template-columns: minmax(150px, 220px) minmax(0, 1fr); gap: 22px; color: inherit; }
      .article-stack p:not(.kicker):not(.byline), .field-grid p:not(.kicker):not(.byline) { color: var(--muted); font-family: var(--font-meta); line-height: 1.55; }
      .byline { margin: 12px 0 0; color: var(--muted); font-family: var(--font-meta); font-size: .75rem; font-weight: 850; }
      .field-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 28px; }
      .field-grid a { color: inherit; text-decoration: none; }
      .field-grid img { margin-bottom: 14px; }
      .all-news > h2 { margin-bottom: 28px; }
      .all-news-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
      .all-news-grid section { padding-top: 14px; border-top: 1px solid var(--hairline); }
      .all-news-grid h3 { margin-bottom: 8px; font-family: var(--font-meta); font-size: .86rem; font-weight: 900; }
      .all-news-grid a { display: block; padding: 11px 0; border-top: 1px solid var(--hairline); font-family: var(--font-headline); font-size: 1.08rem; font-weight: 900; line-height: 1.28; color: inherit; }
      .people-section { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); gap: 36px; align-items: center; }

      .feature-grid, .question-grid, .pillar-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
      .feature-card, .mini-feature, .pillar-card, .question-card, .note-box, .category-feature, .article-toc, .language-box, .book-affiliate, .travel-affiliate, .related-articles article, .share-buttons a, .social-links a { border: 1px solid var(--hairline); background: var(--paper); color: var(--ink); }
      .feature-card, .mini-feature, .pillar-card, .question-card { padding: 16px; }
      .category-hero { padding: 46px 0 32px; border-bottom: 1px solid var(--ink); margin: 0 0 32px; }
      .category-hero h1 { margin-bottom: 16px; font-size: clamp(2.25rem, 5vw, 3.7rem); line-height: 1.04; }
      .category-hero .dek, .dek { max-width: 780px; color: var(--muted); font-family: var(--font-meta); font-size: clamp(1.05rem, 1.5vw, 1.25rem); font-weight: 400; line-height: 1.58; }
      .category-hero__meta { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; color: var(--muted); font-family: var(--font-meta); font-size: .85rem; font-weight: 800; }
      .category-hero__meta span { border: 1px solid var(--hairline); padding: 5px 8px; }
      .category-feature { display: grid; grid-template-columns: minmax(160px, 260px) minmax(0, 1fr); gap: 24px; margin: 34px 0; padding: 22px; }
      .category-feature__mark strong { display: block; font-family: var(--font-headline); font-size: 2.4rem; line-height: 1; }
      .category-feature__mark span { color: var(--muted); font-family: var(--font-meta); font-size: .78rem; font-weight: 800; text-transform: uppercase; }
      .category-note { margin: 32px 0; padding: 18px 20px; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
      .category-questions { margin: 34px 0; }

      .article-page { margin: 0; }
      .article-shell, .article-shell--with-aside { display: grid; grid-template-columns: minmax(180px, 240px) minmax(0, 740px); gap: 40px; padding: 46px 0 64px; border-bottom: 1px solid var(--hairline); }
      .article-shell:not(.article-shell--with-aside) { grid-template-columns: minmax(0, 740px); justify-content: center; }
      .article-aside { position: sticky; top: 24px; align-self: start; }
      .article-body p, .article-body li { color: #202020; font-family: var(--font-body); font-size: 17px; line-height: 1.85; }
      .article-body h2 { margin-top: 42px; margin-bottom: 16px; font-size: 28px; line-height: 1.16; }
      .article-body h2:first-child { margin-top: 0; }
      .article-photo { margin: 28px 0; }
      .article-photo img { aspect-ratio: 3 / 2; object-fit: cover; border: 1px solid var(--hairline); }
      .article-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; margin: 0 0 56px; background: var(--hairline); }
      .article-nav a { padding: 22px; background: var(--paper); font-family: var(--font-meta); font-weight: 900; }

      .site-footer { background: #000000; border-top: 2px solid var(--accent); color: var(--footer-muted); font-family: var(--font-meta); }
      .footer-inner { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; padding: 38px 24px 30px; }
      .site-footer h2 { margin: 0 0 12px; color: #ffffff; font-family: var(--font-meta); font-size: .86rem; font-weight: 900; line-height: 1.2; }
      .site-footer ul { margin: 0; padding: 0; list-style: none; }
      .site-footer li + li { margin-top: 8px; }
      .site-footer a { color: #ffffff; font-size: .88rem; line-height: 1.35; }
      .footer-bottom { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px 12px; padding: 18px 24px 28px; border-top: 1px solid #242424; color: var(--footer-muted); font-size: .75rem; }
      .footer-wordmark { color: #ffffff; font-family: var(--font-headline); font-size: 1.1rem; font-weight: 900; }

      body.reader-large { font-size: 19px; }
      body.reader-large .story-text p:not(.kicker), body.reader-large .article-deck, body.reader-large .people-section p, body.reader-large .path-grid p, body.reader-large .field-grid p:not(.kicker):not(.byline), body.reader-large .article-stack p:not(.kicker):not(.byline), body.reader-large .all-news-grid a { font-size: 1.14rem; }
      body.reader-large .article-body p, body.reader-large .article-body li { font-size: 20px; line-height: 1.95; }

      html.theme-dark body { --paper: #101010; --ink: #ffffff; --muted: #d8d8d8; --hairline: #303030; --hairline-strong: #626262; --accent: #ff4b55; --footer-muted: #d0d0d0; --color-paper: #101010; --color-surface: #101010; --color-ink: #ffffff; --color-muted: #d8d8d8; --color-accent: #ff4b55; --color-border: #303030; color: var(--ink); background: var(--paper); }
      html.theme-dark .masthead, html.theme-dark .path-grid a, html.theme-dark .article-nav a, html.theme-dark .feature-card, html.theme-dark .mini-feature, html.theme-dark .pillar-card, html.theme-dark .question-card, html.theme-dark .note-box, html.theme-dark .category-feature, html.theme-dark .article-toc, html.theme-dark .language-box, html.theme-dark .book-affiliate, html.theme-dark .travel-affiliate, html.theme-dark .related-articles article, html.theme-dark .share-buttons a, html.theme-dark .social-links a { background: var(--paper); border-color: var(--hairline); color: var(--ink); }
      html.theme-dark .menu-button { color: #101010; background: #ffffff; border-color: #ffffff; }
      html.theme-dark .theme-controls button[aria-pressed="true"], html.theme-dark .reader-controls button[aria-pressed="true"] { color: #101010; background: #ffffff; }
      html.theme-dark .article-body p, html.theme-dark .article-body li { color: #ffffff; }
      html.theme-dark figcaption, html.theme-dark .story-text p:not(.kicker), html.theme-dark .article-deck, html.theme-dark .people-section p, html.theme-dark .path-grid p, html.theme-dark .article-stack p:not(.kicker):not(.byline), html.theme-dark .field-grid p:not(.kicker):not(.byline), html.theme-dark .byline, html.theme-dark .post-date, html.theme-dark .article-meta, html.theme-dark .article-aside, html.theme-dark .event-callout, html.theme-dark .dek { color: #d9d9d9; }
      html.theme-dark img { filter: brightness(.93); }

      @media (max-width: 1180px) {
        .utility-row { grid-template-columns: minmax(0, 1fr) auto; grid-template-areas: "left center" "right right"; }
        .utility-right { justify-content: center; }
        .lead-grid { grid-template-columns: 1fr; }
        .right-rail { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 28px; padding-left: 0; border-left: 0; }
        .rail-block + .most-read { margin-top: 0; }
      }

      @media (max-width: 940px) {
        main { padding-right: 22px; padding-left: 22px; }
        .lead-link, .two-column, .article-shell, .article-shell--with-aside, .people-section, .category-feature { grid-template-columns: 1fr; }
        .section-heading, .article-aside { position: static; }
        .path-grid, .field-grid, .all-news-grid, .feature-grid, .question-grid, .pillar-grid { grid-template-columns: 1fr; }
        .footer-inner { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .new-articles-list { grid-template-columns: 1fr; }
        .article-stack a { grid-template-columns: minmax(140px, 210px) minmax(0, 1fr); }
      }

      @media (max-width: 700px) {
        body { font-size: 16px; }
        main { padding-right: 18px; padding-left: 18px; padding-bottom: 56px; }
        .utility-row { grid-template-columns: 1fr; grid-template-areas: "center" "right" "left"; gap: 8px; padding: 8px 12px; text-align: center; }
        .utility-left, .utility-center, .utility-right { justify-content: center; flex-wrap: wrap; gap: 8px; }
        .utility-left { order: 3; font-size: 11px; }
        .language-switcher { width: 100%; overflow-x: auto; padding-bottom: 1px; }
        .language-switcher a, .menu-button { min-height: 28px; padding: 5px 8px; }
        .theme-controls span, .reader-controls span { display: none; }
        .theme-controls button, .reader-controls button { min-width: 28px; }
        .logo-row { padding: 15px 16px 13px; }
        .logo-main { max-width: 11ch; margin: 0 auto; font-size: clamp(1.85rem, 8.7vw, 2.45rem); line-height: 1.04; white-space: normal; }
        .logo-sub { margin-top: 7px; font-size: .62rem; letter-spacing: .06em; }
        .site-motto { max-width: 28rem; font-size: .73rem; }
        .site-motto::before, .site-motto::after { display: none; }
        .section-nav { justify-content: flex-start; gap: 17px; padding: 0 18px; }
        .section-nav a { padding-top: 11px; padding-bottom: 10px; font-size: .82rem; }
        .event-callout { padding: 11px 0; }
        .lead-grid { gap: 22px; padding: 22px 0 34px; }
        .lead-story { padding-bottom: 24px; }
        .lead-link { gap: 18px; }
        .right-rail { grid-template-columns: 1fr; gap: 22px; }
        .rail-card a { grid-template-columns: 72px minmax(0, 1fr); }
        .new-articles, .two-column, .start-paths, .news-band, .all-news, .people-section, .home-section, .editorial-principles { padding: 34px 0; }
        .path-grid a { min-height: 0; padding: 19px; }
        .path-grid span { margin-bottom: 18px; }
        .article-stack a, .rail-card a { grid-template-columns: 1fr; }
        .rail-card img { width: 100%; height: auto; aspect-ratio: 3 / 2; }
        .article-nav { grid-template-columns: 1fr; }
        .footer-inner { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body class={'lang-' + locale}>
    <header class="masthead">
      <div class="utility-row">
        <div class="utility-left"><a href="#main-content">{accessLabel}</a><a href={aboutHref}>{aboutLabel}</a></div>
        <div class="utility-center language-switcher" aria-label="Language">{languageLinks.map((link) => <a class:list={[{ active: link.active }]} href={link.href}>{link.label}</a>)}</div>
        <div class="utility-right">
          <div class="theme-controls" role="group" aria-label={controlCopy.modeGroup}><span>{controlCopy.modeLabel}</span><button type="button" data-theme-mode="light" aria-pressed="false">{controlCopy.light}</button><button type="button" data-theme-mode="dark" aria-pressed="false">{controlCopy.dark}</button></div>
          <div class="reader-controls" role="group" aria-label={controlCopy.sizeGroup}><span>{controlCopy.sizeLabel}</span><button type="button" data-reader-size="medium" aria-pressed="false">{controlCopy.medium}</button><button type="button" data-reader-size="large" aria-pressed="false">{controlCopy.large}</button></div>
          <a href={archiveHref}>{searchLabel}</a><a class="menu-button" href={archiveHref}>{sectionsLabel}</a>
        </div>
      </div>
      <div class="logo-row"><a class="gazette-logo" href={homeHref}><span class="logo-main">{SITE.name}</span><span class="logo-sub">{SITE.tagline}</span></a><p class="site-motto">{motto}</p></div>
      <nav class="section-nav" aria-label="Primary sections">{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}</nav>
    </header>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="footer-inner">
        <section><h2>{footerAbout}</h2><ul>{legalLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul></section>
        <section><h2>{footerSections}</h2><ul>{navLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul></section>
        <section><h2>{footerFollow}</h2><ul><li><a href={SITE.substackUrl}>{subscribeLabel}</a></li>{SITE.socialLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul></section>
      </div>
      <p class="footer-bottom"><span class="footer-wordmark">{SITE.name}</span> © {new Date().getFullYear()} {footerText}</p>
    </footer>
    <script>
      (() => {
        const themeKey = 'inside-japanese-history-theme-mode';
        const sizeKey = 'inside-japanese-history-reader-size';
        const hour = new Date().getHours();
        const autoTheme = hour >= 18 || hour < 6 ? 'dark' : 'light';
        const savedTheme = localStorage.getItem(themeKey) || autoTheme;
        const savedSize = localStorage.getItem(sizeKey) || 'medium';
        const setTheme = (mode) => { document.body.classList.toggle('theme-dark', mode === 'dark'); document.documentElement.classList.toggle('theme-dark', mode === 'dark'); document.documentElement.style.colorScheme = mode === 'dark' ? 'dark' : 'light'; document.querySelectorAll('[data-theme-mode]').forEach((button) => { button.setAttribute('aria-pressed', button.dataset.themeMode === mode ? 'true' : 'false'); }); };
        const setSize = (size) => { document.body.classList.toggle('reader-large', size === 'large'); document.querySelectorAll('[data-reader-size]').forEach((button) => { button.setAttribute('aria-pressed', button.dataset.readerSize === size ? 'true' : 'false'); }); };
        document.querySelectorAll('[data-theme-mode]').forEach((button) => { button.addEventListener('click', () => { const mode = button.dataset.themeMode || autoTheme; localStorage.setItem(themeKey, mode); setTheme(mode); }); });
        document.querySelectorAll('[data-reader-size]').forEach((button) => { button.addEventListener('click', () => { const size = button.dataset.readerSize || 'medium'; localStorage.setItem(sizeKey, size); setSize(size); }); });
        setTheme(savedTheme === 'dark' ? 'dark' : 'light'); setSize(savedSize === 'large' ? 'large' : 'medium');
      })();
    </script>
  </body>
</html>
