---
import Analytics from '../components/Analytics.astro';
import { SITE } from '../consts';
import { localeFromLang, localizedHref, siteTemplate, t } from '../copy/siteTemplate';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  lang?: string;
}

const {
  title,
  description = SITE.description,
  image = '/og-default.png',
  type = 'website',
  canonical,
  lang = SITE.language,
} = Astro.props;

const fullTitle = title === SITE.name ? title : `${title} — ${SITE.name}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const isGerman = lang.startsWith('de');
const isJapanese = lang.startsWith('ja');
const locale = localeFromLang(lang);
const localePrefix = isGerman ? '/de' : isJapanese ? '/ja' : '';
const basePath = Astro.url.pathname
  .replace(/^\/de(?=\/|$)/, '')
  .replace(/^\/ja(?=\/|$)/, '') || '/';
const localizedPaths = new Set([
  '/',
  '/about/',
  '/sengoku/',
  '/bakumatsu/',
  '/hidden-japan/',
  '/articles/japan-creation-dawn/',
  '/categories/beginner/',
  '/categories/history/',
  '/categories/people/',
  '/categories/perspective/',
  '/categories/onsite/',
  '/categories/events/',
]);
const withLocale = (prefix: '' | '/de' | '/ja') => {
  const targetPath = localizedPaths.has(basePath) ? basePath : '/';
  if (targetPath === '/') return `${prefix}/`;
  return `${prefix}${targetPath}`;
};
const languageLinks = [
  { href: withLocale(''), label: 'English', flag: '🇺🇸', active: !isGerman && !isJapanese },
  { href: withLocale('/de'), label: 'Deutsch', flag: '🇩🇪', active: isGerman },
  { href: withLocale('/ja'), label: '日本語', flag: '🇯🇵', active: isJapanese },
];
const navLinks = Object.values(siteTemplate.header.nav).map((link) => ({
  href: localizedHref(link.href, locale),
  label: t(link, locale),
}));
const subscribeLabel = t(siteTemplate.header.subscribe, locale);
const footerText = t(siteTemplate.footer.text, locale);
const legalLinks = Object.values(siteTemplate.footer.legal).map((link) => ({
  href: link.href,
  label: t(link, locale),
}));

const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': new URL('/#organization', Astro.site).toString(),
      name: SITE.name,
      url: SITE.url,
      logo: new URL('/og-default.png', Astro.site).toString(),
    },
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).toString(),
      name: SITE.name,
      alternateName: SITE.tagline,
      url: SITE.url,
      inLanguage: SITE.language,
      publisher: { '@id': new URL('/#organization', Astro.site).toString() },
      potentialAction: {
        '@type': 'SearchAction',
        target: new URL('/?q={search_term_string}', Astro.site).toString(),
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};

const controlCopy = isJapanese
  ? {
      modeGroup: '表示モード',
      modeLabel: '表示',
      light: '明',
      dark: '暗',
      sizeGroup: '文字サイズ',
      sizeLabel: '文字',
      medium: '中',
      large: '大',
    }
  : isGerman
    ? {
        modeGroup: 'Anzeigemodus',
        modeLabel: 'Modus',
        light: 'Hell',
        dark: 'Dunkel',
        sizeGroup: 'Textgroesse',
        sizeLabel: 'Text',
        medium: 'M',
        large: 'G',
      }
    : {
        modeGroup: 'Display mode',
        modeLabel: 'Mode',
        light: 'Light',
        dark: 'Dark',
        sizeGroup: 'Text size',
        sizeLabel: 'Text',
        medium: 'M',
        large: 'L',
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Substack alternate (RSS via Substack while we mirror) -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Newsletter`}
      href={`${SITE.substackUrl}/feed`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Podcast`}
      href={SITE.podcastFeedUrl}
    />
    {languageLinks.map((link) => (
      <link rel="alternate" hreflang={link.label === 'Deutsch' ? 'de' : link.label === '日本語' ? 'ja' : 'en'} href={new URL(link.href, Astro.site).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(withLocale(''), Astro.site).toString()} />

    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} />
    <Analytics />
    <script is:inline>
      (() => {
        try {
          const themeKey = 'inside-japanese-history-theme-mode';
          const hour = new Date().getHours();
          const autoTheme = hour >= 18 || hour < 6 ? 'dark' : 'light';
          const theme = localStorage.getItem(themeKey) || autoTheme;
          document.documentElement.classList.toggle('theme-dark', theme === 'dark');
          document.documentElement.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
        } catch (_) {}
      })();
    </script>

    <style is:global>
      :root {
        --max-width: 800px;
        --wide-width: 1120px;
        --color-paper: #f6f1e8;
        --color-surface: #fffdf8;
        --color-ink: #1b1a17;
        --color-muted: #66615a;
        --color-accent: #9f3a2a;
        --color-indigo: #23313d;
        --color-gold: #b28a45;
        --color-border: #ded3c4;
      }
      html { font-family: Georgia, "Times New Roman", "Hiragino Mincho ProN", serif; color: var(--color-ink); background: var(--color-paper); }
      html.theme-dark { background: #101010; }
      html[lang="ja"] { font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Yu Gothic", "Meiryo", sans-serif; }
      html[lang="ja"] h1,
      html[lang="ja"] h2,
      html[lang="ja"] h3,
      html[lang="ja"] .brand { font-family: "Hiragino Mincho ProN", "Yu Mincho", "YuMincho", Georgia, serif; font-weight: 700; }
      html[lang="ja"] p,
      html[lang="ja"] li { font-size: 1rem; line-height: 1.9; }
      html[lang="ja"] .dek { font-size: 1.08rem; line-height: 1.85; }
      html[lang="ja"] .kicker,
      html[lang="ja"] header.site .links,
      html[lang="ja"] .cta,
      html[lang="ja"] .trust-strip strong,
      html[lang="ja"] .topic-rank .label { font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Yu Gothic", "Meiryo", sans-serif; }
      body { margin: 0; line-height: 1.7; }
      body::before { content: ""; display: block; height: 5px; background: var(--color-indigo); border-bottom: 2px solid var(--color-gold); }
      main { max-width: var(--max-width); margin: 0 auto; padding: 0 1.25rem 4rem; }
      header.site { background: rgba(255, 253, 248, 0.96); border-bottom: 1px solid var(--color-border); }
      header.site nav { max-width: var(--wide-width); margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 1.25rem; flex-wrap: wrap; padding: 1.15rem 1.25rem; }
      header.site .brand { color: var(--color-ink); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 1rem; font-weight: 800; line-height: 1.1; text-decoration: none; text-transform: uppercase; }
      header.site .brand small { display: block; color: var(--color-muted); font-family: Georgia, "Times New Roman", serif; font-size: 0.78rem; font-style: italic; font-weight: 400; margin-top: 0.25rem; text-transform: none; }
      header.site .links { display: flex; align-items: center; flex-wrap: wrap; gap: 0.25rem 0.95rem; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; }
      header.site .links a { color: var(--color-ink); font-size: 0.9rem; font-weight: 650; text-decoration: none; }
      header.site .links a:hover { color: var(--color-accent); }
      header.site .links a.subscribe-link { border: 1px solid var(--color-accent); border-radius: 999px; color: var(--color-accent); padding: 0.45rem 0.75rem; }
      header.site .language-switcher { align-items: center; border-left: 1px solid var(--color-border); display: flex; gap: 0.15rem; margin-left: 0.15rem; padding-left: 0.65rem; }
      header.site .language-switcher a { align-items: center; border: 1px solid transparent; border-radius: 999px; display: inline-flex; font-size: 1.05rem; justify-content: center; line-height: 1; min-height: 2rem; min-width: 2rem; text-decoration: none; }
      header.site .language-switcher a:hover,
      header.site .language-switcher a.active { background: var(--color-surface); border-color: var(--color-border); color: var(--color-accent); }
      .display-controls { display: flex; align-items: center; flex-wrap: wrap; gap: 0.35rem; border-left: 1px solid var(--color-border); margin-left: 0.15rem; padding-left: 0.65rem; }
      .theme-controls,
      .reader-controls { display: inline-flex; align-items: center; gap: 0.15rem; border: 1px solid var(--color-border); border-radius: 4px; background: var(--color-surface); padding: 0.15rem; }
      .theme-controls span,
      .reader-controls span { color: var(--color-muted); font-family: Arial, sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0; padding: 0 0.25rem; text-transform: none; }
      .theme-controls button,
      .reader-controls button { appearance: none; border: 0; border-radius: 3px; background: transparent; color: var(--color-ink); cursor: pointer; font-family: Arial, sans-serif; font-size: 0.78rem; font-weight: 700; line-height: 1; padding: 0.42rem 0.5rem; }
      .theme-controls button[aria-pressed='true'],
      .reader-controls button[aria-pressed='true'] { background: var(--color-ink); color: var(--color-paper); }
      .sr-only { border: 0; clip: rect(0, 0, 0, 0); height: 1px; margin: -1px; overflow: hidden; padding: 0; position: absolute; white-space: nowrap; width: 1px; }
      footer.site { background: var(--color-indigo); color: #f8f1e6; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.9rem; }
      footer.site .footer-inner { max-width: var(--wide-width); margin: 0 auto; padding: 2rem 1.25rem; display: grid; gap: 1rem; grid-template-columns: minmax(0, 1.3fr) minmax(220px, 0.7fr); }
      footer.site a { color: #f8f1e6; }
      footer.site p { margin: 0; }
      .footer-links { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: flex-end; }
      h1 { font-size: 3.25rem; line-height: 1.08; margin: 0.5rem 0 1rem; }
      h2 { margin-top: 2.6rem; font-size: 1.45rem; line-height: 1.25; }
      h3 { line-height: 1.3; }
      p, li { font-size: 1.03rem; }
      a { color: var(--color-accent); }
      .kicker { color: var(--color-accent); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.78rem; font-weight: 800; margin: 0 0 0.5rem; text-transform: uppercase; }
      .dek { color: var(--color-muted); font-size: 1.18rem; line-height: 1.55; }
      .hero { border-bottom: 1px solid var(--color-border); margin-bottom: 2.25rem; padding: 2.25rem 0 2rem; }
      .visual-hero { background: #141a1f; color: #fffaf0; margin: 0 calc(50% - 50vw) 2.2rem; min-height: 500px; overflow: hidden; position: relative; width: 100vw; }
      .hero-slides { inset: 0; position: absolute; }
      .hero-slide { background-position: center; background-size: cover; inset: 0; opacity: 0; position: absolute; transform: scale(1.02); transition: opacity 1200ms ease; }
      .hero-slide.active { opacity: 1; }
      .hero-slideshow { transition: background-image 600ms ease-in-out; }
      .visual-hero::before { background: linear-gradient(90deg, rgba(18, 25, 30, 0.84), rgba(18, 25, 30, 0.54) 48%, rgba(18, 25, 30, 0.12)); content: ""; inset: 0; position: absolute; }
      .visual-hero .inner { max-width: var(--wide-width); margin: 0 auto; padding: 4.4rem 1.25rem 3.4rem; position: relative; }
      .visual-hero .copy { background: rgba(16, 20, 23, 0.62); border: 1px solid rgba(255,255,255,0.18); border-radius: 8px; box-shadow: 0 24px 70px rgba(0,0,0,0.32); box-sizing: border-box; padding: 2rem 2.1rem 2.05rem; width: 100%; }
      .visual-hero h1 { color: #fffaf0; font-size: 4.2rem; max-width: none; }
      .visual-hero h1 span { display: block; }
      html[lang="de"] .visual-hero h1 { font-size: 3.65rem; }
      html[lang="ja"] .visual-hero h1 { font-size: 3.15rem; line-height: 1.18; }
      .visual-hero .dek { color: #f4e9d8; font-size: 1.2rem; max-width: none; }
      html[lang="de"] .visual-hero .dek { font-size: 1.08rem; }
      .visual-hero .kicker { color: #f0c46a; }
      .visual-hero h1,
      .visual-hero .dek,
      .visual-hero .kicker { text-shadow: 0 2px 18px rgba(0,0,0,0.55); }
      .visual-hero .cta.secondary { border-color: rgba(255,255,255,0.45); color: #fffaf0; }
      .visual-hero .image-credit { bottom: 1rem; color: rgba(255,255,255,0.7); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.75rem; position: absolute; right: 1.25rem; }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.3rem; }
      .trust-strip { border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); color: var(--color-muted); display: grid; gap: 0.7rem; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin: 2rem 0; padding: 1rem 0; }
      .trust-strip strong { color: var(--color-ink); display: block; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.85rem; text-transform: uppercase; }
      .home-intro { margin: 3rem calc(50% - min(50vw, var(--wide-width) / 2)); padding: 0 1.25rem; }
      .home-intro h2 { font-size: 2.45rem; letter-spacing: 0; line-height: 1.08; margin: 0 0 1rem; max-width: 780px; }
      .home-intro p:not(.kicker) { color: var(--color-muted); font-size: 1.18rem; line-height: 1.72; max-width: 880px; }
      .authority-note { border-left: 4px solid var(--color-accent); margin: 2rem 0; padding: 0.2rem 0 0.2rem 1rem; }
      .authority-note h2 { font-size: 1.35rem; margin: 0 0 0.45rem; }
      .authority-note p:last-child { color: var(--color-muted); margin: 0; }
      .editorial-map { border-bottom: 1px solid var(--color-border); border-top: 1px solid var(--color-border); display: grid; gap: 1.5rem; grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr); margin: 2.25rem calc(50% - min(50vw, var(--wide-width) / 2)) 2.4rem; padding: 2rem 1.25rem; }
      .editorial-map.refined { background: rgba(255,253,248,0.52); border-color: #d6c6b3; padding-bottom: 2.4rem; padding-top: 2.4rem; }
      .editorial-map h2 { margin: 0; }
      .editorial-map p:last-child { color: var(--color-muted); margin: 0.25rem 0 0; }
      .feature-showcase { align-items: stretch; background: #fffaf1; border-bottom: 1px solid var(--color-border); border-top: 1px solid var(--color-border); display: grid; gap: 0; grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.78fr); margin: 3rem calc(50% - min(50vw, var(--wide-width) / 2)); }
      .feature-showcase img { display: block; height: 100%; min-height: 390px; object-fit: cover; width: 100%; }
      .feature-showcase > div { align-self: center; padding: 2.3rem; }
      .feature-showcase h2 { font-size: 2rem; line-height: 1.12; margin: 0 0 0.85rem; }
      .feature-showcase p:not(.kicker) { color: var(--color-muted); font-size: 1.05rem; }
      .text-link { color: var(--color-accent); display: inline-block; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.92rem; font-weight: 800; margin-top: 0.4rem; text-decoration: none; text-transform: uppercase; }
      .text-link::after { content: " →"; }
      .home-section { margin: 3.2rem calc(50% - min(50vw, var(--wide-width) / 2)); padding: 0 1.25rem; }
      .section-heading { max-width: 760px; }
      .section-heading h2 { font-size: 2rem; line-height: 1.15; margin: 0 0 0.75rem; }
      .section-heading p:not(.kicker) { color: var(--color-muted); font-size: 1.08rem; margin-top: 0; }
      .pillar-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin: 1.5rem 0 2rem; }
      .pillar-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 7px; padding: 1.2rem; }
      .pillar-grid.polished { gap: 1.15rem; grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .pillar-grid.polished .pillar-card { background: rgba(255,253,248,0.86); border-color: #dacdbc; box-shadow: 0 14px 35px rgba(65, 45, 26, 0.06); min-height: 175px; }
      .pillar-card h3 { margin-top: 0; }
      .pillar-card p { color: var(--color-muted); font-size: 0.96rem; }
      .topic-rank { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); margin: 1.35rem 0 2.4rem; }
      .topic-rank > div { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 1.05rem; }
      .topic-rank .label { color: var(--color-accent); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.74rem; font-weight: 800; margin: 0; text-transform: uppercase; }
      .topic-rank h3 { font-size: 1.05rem; margin: 0.35rem 0; }
      .topic-rank p { color: var(--color-muted); font-size: 0.94rem; margin-bottom: 0; }
      .feature-grid { display: grid; gap: 1rem; grid-template-columns: minmax(0, 1.25fr) minmax(260px, 0.75fr); margin: 1.5rem 0 2.5rem; }
      .feature-grid.elevated { gap: 1.25rem; }
      .feature-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; }
      .feature-grid.elevated .feature-card,
      .feature-grid.elevated .mini-feature { box-shadow: 0 16px 42px rgba(65, 45, 26, 0.08); }
      .feature-card img { aspect-ratio: 16 / 9; display: block; height: auto; object-fit: cover; width: 100%; }
      .feature-card .body { padding: 1rem 1.1rem 1.2rem; }
      .feature-card .label { color: var(--color-accent); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.76rem; font-weight: 800; text-transform: uppercase; }
      .feature-card h3 { font-size: 1.35rem; margin: 0.35rem 0 0.45rem; }
      .feature-card p { color: var(--color-muted); margin: 0; }
      .feature-list { display: grid; gap: 1rem; }
      .mini-feature { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; display: grid; gap: 0.8rem; grid-template-columns: 96px minmax(0, 1fr); overflow: hidden; }
      .mini-feature img { height: 100%; min-height: 112px; object-fit: cover; width: 100%; }
      .mini-feature div { padding: 0.85rem 0.9rem 0.85rem 0; }
      .mini-feature .label { color: var(--color-accent); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.72rem; font-weight: 800; text-transform: uppercase; }
      .mini-feature h3 { font-size: 1rem; margin: 0.25rem 0; }
      .mini-feature p { color: var(--color-muted); font-size: 0.9rem; margin: 0; }
      .cta { display: inline-block; background: var(--color-accent); color: white; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-weight: 750; padding: 0.75rem 1.05rem; border-radius: 4px; text-decoration: none; }
      .cta.secondary { background: transparent; border: 1px solid var(--color-border); color: var(--color-ink); }
      .note-box { background: var(--color-surface); border: 1px solid var(--color-border); border-left: 4px solid var(--color-gold); border-radius: 6px; padding: 1rem 1.1rem; }
      .editorial-principles { display: grid; gap: 2rem; grid-template-columns: minmax(260px, 0.75fr) minmax(0, 1fr); margin: 3.6rem calc(50% - min(50vw, var(--wide-width) / 2)); padding: 0 1.25rem 0.4rem; }
      .editorial-principles h2 { font-size: 2rem; line-height: 1.15; margin: 0; }
      .editorial-principles ol { border-top: 1px solid var(--color-border); list-style: none; margin: 0; padding: 0; }
      .editorial-principles li { border-bottom: 1px solid var(--color-border); display: grid; gap: 0.8rem; grid-template-columns: minmax(190px, 0.55fr) minmax(0, 1fr); padding: 1.1rem 0; }
      .editorial-principles strong { font-size: 1.02rem; line-height: 1.35; }
      .editorial-principles span { color: var(--color-muted); display: block; font-size: 0.98rem; line-height: 1.65; }
      .category-hero { border-bottom: 1px solid var(--color-border); margin: 0 calc(50% - min(50vw, var(--wide-width) / 2)) 2.8rem; padding: 3.2rem 1.25rem 2.4rem; }
      .category-hero h1 { font-size: 3.65rem; letter-spacing: 0; line-height: 1.04; max-width: 900px; }
      .category-hero .dek { color: var(--color-muted); font-size: 1.28rem; line-height: 1.65; max-width: 820px; }
      .category-hero__meta { color: var(--color-muted); display: flex; flex-wrap: wrap; gap: 0.55rem 1rem; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.82rem; margin-top: 1.2rem; text-transform: uppercase; }
      .category-feature { background: #fffaf1; border-bottom: 1px solid var(--color-border); border-top: 1px solid var(--color-border); display: grid; gap: 0; grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr); margin: 2.5rem calc(50% - min(50vw, var(--wide-width) / 2)); }
      .category-feature__mark { align-content: center; background: var(--color-indigo); color: #fffaf0; display: grid; min-height: 260px; padding: 2rem; }
      .category-feature__mark strong { display: block; font-size: 2.65rem; line-height: 1.05; }
      .category-feature__mark span { color: #e5c789; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.84rem; font-weight: 800; margin-top: 0.8rem; text-transform: uppercase; }
      .category-feature__body { align-self: center; padding: 2rem 2.2rem; }
      .category-feature h2 { font-size: 2rem; line-height: 1.12; margin: 0 0 0.85rem; }
      .category-feature p:not(.kicker) { color: var(--color-muted); font-size: 1.06rem; }
      .category-questions { margin: 3rem calc(50% - min(50vw, var(--wide-width) / 2)); padding: 0 1.25rem; }
      .category-questions h2 { font-size: 2rem; line-height: 1.15; margin-bottom: 1rem; }
      .question-grid { display: grid; gap: 1rem; grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .question-card { background: rgba(255,253,248,0.88); border: 1px solid var(--color-border); border-radius: 8px; box-shadow: 0 14px 35px rgba(65, 45, 26, 0.06); padding: 1.15rem; }
      .question-card .label { color: var(--color-accent); font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif; font-size: 0.72rem; font-weight: 800; margin: 0 0 0.45rem; text-transform: uppercase; }
      .question-card h3 { font-size: 1.08rem; margin: 0 0 0.45rem; }
      .question-card p { color: var(--color-muted); font-size: 0.94rem; margin: 0; }
      .category-note { border-left: 4px solid var(--color-gold); color: var(--color-muted); margin: 2.5rem 0; padding: 0.2rem 0 0.2rem 1rem; }
      html.theme-dark body {
        --color-paper: #101010;
        --color-surface: #181818;
        --color-ink: #ffffff;
        --color-muted: #d8d8d8;
        --color-accent: #ff6b5d;
        --color-indigo: #050505;
        --color-gold: #e1b95f;
        --color-border: #303030;
        background: var(--color-paper);
        color: var(--color-ink);
      }
      html.theme-dark body::before { background: #000000; border-bottom-color: var(--color-gold); }
      html.theme-dark body header.site { background: rgba(16, 16, 16, 0.96); }
      html.theme-dark body p,
      html.theme-dark body li,
      html.theme-dark body .article-body p,
      html.theme-dark body .article-body li { color: var(--color-ink); }
      html.theme-dark body .dek,
      html.theme-dark body .meta,
      html.theme-dark body .eyebrow,
      html.theme-dark body .brand small,
      html.theme-dark body footer.site,
      html.theme-dark body footer.site a { color: var(--color-muted); }
      html.theme-dark body .pillar-card,
      html.theme-dark body .feature-card,
      html.theme-dark body .mini-feature,
      html.theme-dark body .question-card,
      html.theme-dark body .note-box,
      html.theme-dark body .language-box,
      html.theme-dark body .article-toc,
      html.theme-dark body .book-affiliate,
      html.theme-dark body .travel-affiliate,
      html.theme-dark body .related-articles article,
      html.theme-dark body .share-buttons a,
      html.theme-dark body .social-links a,
      html.theme-dark body .category-feature,
      html.theme-dark body .feature-showcase,
      html.theme-dark body .editorial-map { background: var(--color-surface); border-color: var(--color-border); color: var(--color-ink); }
      html.theme-dark body .visual-hero,
      html.theme-dark body footer.site { background: #000000; }
      html.theme-dark body img { filter: brightness(0.92); }
      body.reader-large { font-size: 19px; }
      body.reader-large p,
      body.reader-large li,
      body.reader-large .article-body p,
      body.reader-large .article-body li { font-size: 1.16rem; line-height: 1.86; }
      body.reader-large .dek { font-size: 1.28rem; }

      @media (max-width: 700px) {
        header.site .links { width: 100%; }
        .display-controls { border-left: 0; padding-left: 0; width: 100%; }
        .theme-controls,
        .reader-controls { flex: 1 1 9rem; }
        .theme-controls button,
        .reader-controls button { flex: 1; }
        h1 { font-size: 2rem; }
        .visual-hero { min-height: 430px; }
        .visual-hero::before { background: linear-gradient(180deg, rgba(18, 25, 30, 0.86), rgba(18, 25, 30, 0.54)); }
        .visual-hero .inner { padding-top: 2.4rem; }
        .visual-hero .copy { padding: 1.2rem; }
        .visual-hero h1,
        html[lang="de"] .visual-hero h1,
        html[lang="ja"] .visual-hero h1 { font-size: 2.35rem; }
        .visual-hero .dek,
        html[lang="de"] .visual-hero .dek { font-size: 1.05rem; }
        .editorial-map { grid-template-columns: 1fr; margin-left: 0; margin-right: 0; padding-left: 0; padding-right: 0; }
        .home-intro,
        .home-section,
        .editorial-principles { margin-left: 0; margin-right: 0; padding-left: 0; padding-right: 0; }
        .home-intro h2,
        .section-heading h2,
        .editorial-principles h2 { font-size: 1.75rem; }
        .feature-showcase { grid-template-columns: 1fr; margin-left: 0; margin-right: 0; }
        .feature-showcase img { min-height: 260px; }
        .feature-showcase > div { padding: 1.2rem; }
        .feature-grid { grid-template-columns: 1fr; }
        .pillar-grid.polished { grid-template-columns: 1fr; }
        .editorial-principles { grid-template-columns: 1fr; }
        .editorial-principles li { grid-template-columns: 1fr; }
        .category-hero { margin-left: 0; margin-right: 0; padding-left: 0; padding-right: 0; }
        .category-hero h1 { font-size: 2.35rem; }
        .category-hero .dek { font-size: 1.08rem; }
        .category-feature { grid-template-columns: 1fr; margin-left: 0; margin-right: 0; }
        .category-feature__mark { min-height: 170px; padding: 1.2rem; }
        .category-feature__body { padding: 1.25rem; }
        .category-questions { margin-left: 0; margin-right: 0; padding-left: 0; padding-right: 0; }
        .question-grid { grid-template-columns: 1fr; }
        footer.site .footer-inner { grid-template-columns: 1fr; }
        .footer-links { justify-content: flex-start; }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <nav>
        <a class="brand" href={isGerman ? '/de/' : isJapanese ? '/ja/' : '/'}>
          {SITE.name}
          <small>{SITE.tagline}</small>
        </a>
        <div class="links">
          {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          <a class="subscribe-link" href={SITE.substackUrl}>{subscribeLabel}</a>
          <div class="display-controls" aria-label={controlCopy.modeGroup}>
            <div class="theme-controls" role="group" aria-label={controlCopy.modeGroup}>
              <span>{controlCopy.modeLabel}</span>
              <button type="button" data-theme-mode="light" aria-pressed="false">{controlCopy.light}</button>
              <button type="button" data-theme-mode="dark" aria-pressed="false">{controlCopy.dark}</button>
            </div>
            <div class="reader-controls" role="group" aria-label={controlCopy.sizeGroup}>
              <span>{controlCopy.sizeLabel}</span>
              <button type="button" data-reader-size="medium" aria-pressed="false">{controlCopy.medium}</button>
              <button type="button" data-reader-size="large" aria-pressed="false">{controlCopy.large}</button>
            </div>
          </div>
          <div class="language-switcher" aria-label="Language">
            {languageLinks.map((link) => (
              <a class:list={[{ active: link.active }]} href={link.href} aria-label={link.label} title={link.label}>
                <span aria-hidden="true">{link.flag}</span>
                <span class="sr-only">{link.label}</span>
              </a>
            ))}
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <div class="footer-inner">
        <p>
          © {new Date().getFullYear()} {SITE.name}. {footerText}
        </p>
        <div class="footer-links">
          {legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          {SITE.socialLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </div>
    </footer>
    <script>
      (() => {
        const themeKey = 'inside-japanese-history-theme-mode';
        const sizeKey = 'inside-japanese-history-reader-size';
        const hour = new Date().getHours();
        const autoTheme = hour >= 18 || hour < 6 ? 'dark' : 'light';
        const savedTheme = localStorage.getItem(themeKey) || autoTheme;
        const savedSize = localStorage.getItem(sizeKey) || 'medium';

        const setTheme = (mode) => {
          document.body.classList.toggle('theme-dark', mode === 'dark');
          document.documentElement.classList.toggle('theme-dark', mode === 'dark');
          document.documentElement.style.colorScheme = mode === 'dark' ? 'dark' : 'light';
          document.querySelectorAll('[data-theme-mode]').forEach((button) => {
            button.setAttribute('aria-pressed', button.dataset.themeMode === mode ? 'true' : 'false');
          });
        };

        const setSize = (size) => {
          document.body.classList.toggle('reader-large', size === 'large');
          document.querySelectorAll('[data-reader-size]').forEach((button) => {
            button.setAttribute('aria-pressed', button.dataset.readerSize === size ? 'true' : 'false');
          });
        };

        document.querySelectorAll('[data-theme-mode]').forEach((button) => {
          button.addEventListener('click', () => {
            const mode = button.dataset.themeMode || autoTheme;
            localStorage.setItem(themeKey, mode);
            setTheme(mode);
          });
        });

        document.querySelectorAll('[data-reader-size]').forEach((button) => {
          button.addEventListener('click', () => {
            const size = button.dataset.readerSize || 'medium';
            localStorage.setItem(sizeKey, size);
            setSize(size);
          });
        });

        setTheme(savedTheme === 'dark' ? 'dark' : 'light');
        setSize(savedSize === 'large' ? 'large' : 'medium');
      })();
    </script>
  </body>
</html>
