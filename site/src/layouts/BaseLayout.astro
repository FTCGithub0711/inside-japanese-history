---
import Analytics from '../components/Analytics.astro';
import { SITE } from '../consts';
import { localeFromLang, localizedHref, siteTemplate, t } from '../copy/siteTemplate';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  lang?: string;
}

const {
  title,
  description = SITE.description,
  image = '/og-default.png',
  type = 'website',
  canonical,
  lang = SITE.language,
} = Astro.props;

const fullTitle = title === SITE.name ? title : title + ' — ' + SITE.name;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const isGerman = lang.startsWith('de');
const isJapanese = lang.startsWith('ja');
const locale = localeFromLang(lang);
const basePath = Astro.url.pathname
  .replace(/^\/de(?=\/|$)/, '')
  .replace(/^\/ja(?=\/|$)/, '') || '/';
const localizedPaths = new Set([
  '/',
  '/about/',
  '/sengoku/',
  '/bakumatsu/',
  '/hidden-japan/',
  '/articles/japan-creation-dawn/',
  '/categories/beginner/',
  '/categories/history/',
  '/categories/people/',
  '/categories/perspective/',
  '/categories/onsite/',
  '/categories/events/',
]);
const withLocale = (prefix: '' | '/de' | '/ja') => {
  const targetPath = localizedPaths.has(basePath) ? basePath : '/';
  if (targetPath === '/') return prefix + '/';
  return prefix + targetPath;
};
const languageLinks = [
  { href: withLocale(''), label: 'English', active: !isGerman && !isJapanese },
  { href: withLocale('/de'), label: 'Deutsch', active: isGerman },
  { href: withLocale('/ja'), label: '日本語', active: isJapanese },
];
const navLinks = Object.values(siteTemplate.header.nav).map((link) => ({
  href: localizedHref(link.href, locale),
  label: t(link, locale),
}));
const subscribeLabel = t(siteTemplate.header.subscribe, locale);
const footerText = t(siteTemplate.footer.text, locale);
const legalLinks = Object.values(siteTemplate.footer.legal).map((link) => ({
  href: link.href,
  label: t(link, locale),
}));
const homeHref = isGerman ? '/de/' : isJapanese ? '/ja/' : '/';
const aboutHref = localizedHref('/about/', locale);
const archiveHref = localizedHref('/categories/history/', locale);
const searchLabel = isJapanese ? '検索' : isGerman ? 'Suche' : 'Search';
const sectionsLabel = isJapanese ? '目次' : isGerman ? 'Rubriken' : 'Sections';
const motto = isJapanese
  ? '日本史を、物語と現地の手がかりから読む。'
  : isGerman
    ? 'Japanische Geschichte durch Erzaehlung, Orte und Quellen lesen.'
    : 'Read Japanese history through story, places, and sources.';
const footerAbout = isJapanese ? 'このサイトについて' : isGerman ? 'Ueber diese Seite' : 'About';
const footerSections = isJapanese ? '目次' : isGerman ? 'Rubriken' : 'Sections';
const footerFollow = isJapanese ? 'フォロー' : isGerman ? 'Folgen' : 'Follow';
const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': new URL('/#organization', Astro.site).toString(),
      name: SITE.name,
      url: SITE.url,
      logo: new URL('/og-default.png', Astro.site).toString(),
    },
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).toString(),
      name: SITE.name,
      alternateName: SITE.tagline,
      url: SITE.url,
      inLanguage: SITE.language,
      publisher: { '@id': new URL('/#organization', Astro.site).toString() },
      potentialAction: {
        '@type': 'SearchAction',
        target: new URL('/?q={search_term_string}', Astro.site).toString(),
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
const controlCopy = isJapanese
  ? { modeGroup: '表示モード', modeLabel: '表示', light: '明', dark: '暗', sizeGroup: '文字サイズ', sizeLabel: '文字', medium: '中', large: '大' }
  : isGerman
    ? { modeGroup: 'Anzeigemodus', modeLabel: 'Modus', light: 'Hell', dark: 'Dunkel', sizeGroup: 'Textgroesse', sizeLabel: 'Text', medium: 'M', large: 'G' }
    : { modeGroup: 'Display mode', modeLabel: 'Mode', light: 'Light', dark: 'Dark', sizeGroup: 'Text size', sizeLabel: 'Text', medium: 'M', large: 'L' };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title={SITE.name + ' — Newsletter'} href={SITE.substackUrl + '/feed'} />
    <link rel="alternate" type="application/rss+xml" title={SITE.name + ' — Podcast'} href={SITE.podcastFeedUrl} />
    {languageLinks.map((link) => (
      <link rel="alternate" hreflang={link.label === 'Deutsch' ? 'de' : link.label === '日本語' ? 'ja' : 'en'} href={new URL(link.href, Astro.site).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(withLocale(''), Astro.site).toString()} />
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} />
    <Analytics />
    <script is:inline>
      (() => {
        try {
          const themeKey = 'inside-japanese-history-theme-mode';
          const hour = new Date().getHours();
          const autoTheme = hour >= 18 || hour < 6 ? 'dark' : 'light';
          const theme = localStorage.getItem(themeKey) || autoTheme;
          document.documentElement.classList.toggle('theme-dark', theme === 'dark');
          document.documentElement.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
        } catch (_) {}
      })();
    </script>
    <style is:global>
      :root { color-scheme: light; --font-headline: "Postoni", "Bodoni 72", "Playfair Display", Georgia, "Times New Roman", serif; --font-body: Georgia, "Times New Roman", serif; --font-meta: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif; --fs-075: .75rem; --fs-087: .875rem; --fs-100: 1rem; --fs-112: 1.125rem; --fs-125: 1.25rem; --fs-150: 1.5rem; --fs-200: 2rem; --fs-250: 2.5rem; --fs-350: 3.5rem; --lh-110: 1.1; --lh-160: 1.6; --gray400: #e9e9e9; --gray300: #d4d4d4; --gray80: #595959; --red100: #ea0017; --ink: #111111; --paper: #ffffff; --footer-muted: #a1a1a1; --max-page: 1240px; --max-width: 800px; --wide-width: 1240px; --color-paper: var(--paper); --color-surface: var(--paper); --color-ink: var(--ink); --color-muted: var(--gray80); --color-accent: var(--red100); --color-indigo: #000000; --color-gold: var(--red100); --color-border: var(--gray400); }
      * { box-sizing: border-box; }
      html { background: var(--paper); color: var(--ink); font-family: var(--font-body); scroll-behavior: smooth; }
      html[lang^="ja"] { --font-headline: "Hiragino Mincho ProN", "Yu Mincho", YuMincho, "Noto Serif JP", serif; --font-body: "Hiragino Mincho ProN", "Yu Mincho", YuMincho, "Noto Serif JP", serif; --font-meta: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Yu Gothic", Meiryo, sans-serif; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--font-meta); font-size: 17px; line-height: var(--lh-160); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
      body::before { display: none; }
      a { color: inherit; } img { display: block; width: 100%; height: auto; } figure { margin: 0; } figcaption { margin-top: 8px; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-075); line-height: 1.4; }
      h1, h2, h3, p { margin-top: 0; } h1, h2, h3 { font-family: var(--font-headline); font-weight: 900; letter-spacing: 0; } h1 { margin-bottom: 16px; font-size: var(--fs-250); line-height: var(--lh-110); } h2 { margin-bottom: 24px; font-size: var(--fs-200); line-height: var(--lh-110); } h3 { margin-bottom: 8px; font-size: var(--fs-125); line-height: 1.2; } p, li { font-size: 1rem; }
      .utility-row, .logo-row, .section-nav, main, .footer-inner, .footer-bottom { max-width: var(--max-page); margin: 0 auto; }
      .masthead { background: var(--paper); border-bottom: 1px solid var(--gray400); }
      .utility-row { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px; padding: 9px 20px; border-bottom: 1px solid var(--gray400); color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-075); font-weight: 700; }
      .utility-left, .utility-center, .utility-right { display: flex; align-items: center; gap: 16px; min-width: 0; } .utility-center { justify-content: center; } .utility-right { justify-content: flex-end; }
      .utility-row a, .theme-controls button, .reader-controls button, .section-nav a, .lead-story a, .rail-card a, .article-stack a, .path-grid a, .all-news a, .text-link, .site-footer a, .article-nav a, .new-articles-list a, .category-list a { text-decoration: none; }
      .menu-button { display: inline-flex; align-items: center; min-height: 28px; padding: 4px 10px; color: var(--paper); background: var(--ink); border: 1px solid var(--ink); font-family: var(--font-meta); font-size: var(--fs-075); font-weight: 800; line-height: 1; }
      .language-switcher { display: flex; align-items: center; gap: 6px; } .language-switcher a { padding: 4px 8px; border: 1px solid transparent; font-size: var(--fs-075); font-weight: 800; text-decoration: none; } .language-switcher a.active { border-color: currentColor; color: var(--ink); }
      .theme-controls, .reader-controls { display: inline-flex; align-items: center; gap: 2px; min-height: 28px; padding: 2px; border: 1px solid var(--gray300); color: var(--ink); background: var(--paper); font-family: var(--font-meta); line-height: 1; }
      .theme-controls span, .reader-controls span { padding: 0 6px; color: var(--gray80); font-size: var(--fs-075); font-weight: 900; } .theme-controls button, .reader-controls button { min-width: 30px; min-height: 24px; padding: 3px 7px; border: 0; color: var(--ink); background: transparent; font-family: var(--font-meta); font-size: var(--fs-075); font-weight: 900; line-height: 1; cursor: pointer; } .theme-controls button[aria-pressed="true"], .reader-controls button[aria-pressed="true"] { color: var(--paper); background: var(--ink); }
      .logo-row { display: grid; place-items: center; gap: 8px; padding: 20px 20px 16px; text-align: center; } .gazette-logo { display: block; color: var(--ink); line-height: 1; text-decoration: none; } .logo-main { display: block; font-family: var(--font-headline); font-size: 64px; font-weight: 900; line-height: 1; } .logo-sub { display: block; margin-top: 8px; color: var(--ink); font-family: var(--font-meta); font-size: .6875rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; } .site-motto { margin: 0; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-075); font-weight: 500; } .site-motto::before, .site-motto::after { content: ""; display: inline-block; width: 36px; height: 1px; margin: 0 8px 3px; background: var(--gray400); }
      .section-nav { display: flex; justify-content: center; gap: 24px; overflow-x: auto; padding: 0 20px; border-top: 1px solid var(--gray400); border-bottom: 1px solid var(--gray400); scrollbar-width: none; } .section-nav::-webkit-scrollbar { display: none; } .section-nav a { flex: 0 0 auto; padding: 12px 0 10px; border-bottom: 3px solid transparent; color: var(--ink); font-family: var(--font-meta); font-size: var(--fs-087); font-weight: 800; line-height: 1; } .section-nav a:hover, .section-nav a[aria-current="page"] { border-bottom-color: var(--ink); }
      main { padding: 0 20px 64px; } main > * { min-width: 0; } .sr-only { border: 0; clip: rect(0, 0, 0, 0); height: 1px; margin: -1px; overflow: hidden; padding: 0; position: absolute; white-space: nowrap; width: 1px; }
      .event-callout { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--gray400); color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-087); } .event-callout strong { color: var(--ink); font-weight: 900; }
      .lead-grid { display: grid; grid-template-columns: minmax(0, 15fr) minmax(300px, 4fr); gap: 32px; padding: 32px 0 44px; border-bottom: 1px solid var(--gray400); } .lead-story { padding-bottom: 32px; border-bottom: 1px solid var(--gray400); } .lead-link { display: grid; grid-template-columns: minmax(0, .86fr) minmax(380px, 1.14fr); gap: 32px; align-items: start; }
      .story-text p:not(.kicker), .article-deck, .people-section p { color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-112); font-weight: 400; line-height: 1.55; } .story-art img, .article-hero img, .article-stack img, .field-grid img, .people-section img, .feature-card img, .mini-feature img { aspect-ratio: 3 / 2; object-fit: cover; background: var(--gray400); }
      .kicker, .section-label { margin: 0 0 8px; color: var(--ink); font-family: var(--font-meta); font-weight: 800; line-height: 1.2; text-transform: none; } .kicker { font-size: var(--fs-087); } .section-label { font-size: var(--fs-100); } .read-more, .text-link { display: inline-flex; align-items: center; gap: 8px; color: var(--ink); font-family: var(--font-meta); font-size: var(--fs-100); font-weight: 900; } .read-more { margin-top: 8px; } .read-more::after, .text-link::after { content: "→"; color: var(--red100); font-weight: 900; }
      .right-rail { min-width: 0; padding-left: 24px; border-left: 1px solid var(--gray400); } .rail-block + .most-read { margin-top: 32px; } .rail-card { border-top: 1px solid var(--gray400); } .rail-card a { display: grid; grid-template-columns: 80px minmax(0, 1fr); gap: 12px; padding: 12px 0; } .rail-card img { width: 80px; height: 80px; object-fit: cover; } .rail-card h3 { margin: 0; font-size: var(--fs-100); line-height: 1.2; } .rail-card .kicker { margin-bottom: 4px; font-size: var(--fs-075); }
      .most-read { border-top: 1px solid var(--ink); padding-top: 16px; } .most-read ol { margin: 0; padding: 0; list-style: none; counter-reset: most-read; } .most-read li { display: grid; grid-template-columns: 36px minmax(0, 1fr); gap: 12px; padding: 12px 0; border-top: 1px solid var(--gray400); counter-increment: most-read; } .most-read li::before { content: counter(most-read); color: var(--red100); font-family: var(--font-headline); font-size: var(--fs-200); font-weight: 900; line-height: 1; } .most-read a { font-family: var(--font-meta); font-size: var(--fs-100); font-weight: 800; line-height: 1.3; }
      .new-articles, .two-column, .start-paths, .news-band, .all-news, .travel-section, .people-section, .home-section, .editorial-principles { padding: 48px 0; border-bottom: 1px solid var(--gray400); } .section-heading { position: sticky; top: 24px; align-self: start; max-width: none; } .section-heading h2 { margin-top: 0; } .new-articles > .section-heading, .news-band > .section-heading { position: static; margin-bottom: 32px; }
      .new-articles-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 32px; margin: 0 0 24px; padding: 0; list-style: none; } .new-articles-list li { border-top: 1px solid var(--gray400); } .new-articles-list a { display: block; padding: 16px 0; color: inherit; } .new-articles-list time, .post-date { display: block; margin-bottom: 6px; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-075); font-weight: 700; } .new-articles-list h3 { margin: 0 0 8px; font-size: var(--fs-150); } .new-articles-list p:not(.kicker) { margin: 0; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-100); line-height: 1.55; }
      .path-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1px; background: var(--gray400); border-top: 1px solid var(--gray400); border-bottom: 1px solid var(--gray400); } .path-grid a { position: relative; min-height: 220px; padding: 24px; overflow: hidden; background: var(--paper); } .path-grid span { display: block; margin-bottom: 54px; color: var(--gray300); font-family: var(--font-headline); font-size: var(--fs-350); font-weight: 900; line-height: .8; } .path-grid strong { display: block; margin-bottom: 12px; font-family: var(--font-headline); font-size: var(--fs-150); font-weight: 900; line-height: 1.15; } .path-grid p { margin-bottom: 0; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-100); }
      .two-column { display: grid; grid-template-columns: 330px minmax(0, 1fr); gap: 40px; } .article-stack { display: grid; gap: 32px; } .article-stack article, .field-grid article { border-top: 1px solid var(--gray400); padding-top: 16px; } .article-stack a { display: grid; grid-template-columns: 220px minmax(0, 1fr); gap: 24px; color: inherit; } .article-stack p:not(.kicker):not(.byline), .field-grid p:not(.kicker):not(.byline) { color: var(--gray80); font-family: var(--font-meta); } .byline { margin: 12px 0 0; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-075); font-weight: 800; }
      .field-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; } .field-grid a { color: inherit; text-decoration: none; } .field-grid img { margin-bottom: 16px; } .all-news > h2 { margin-bottom: 32px; } .all-news-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; } .all-news-grid section { padding-top: 16px; border-top: 1px solid var(--gray400); } .all-news-grid h3 { margin-bottom: 8px; font-family: var(--font-meta); font-size: var(--fs-087); font-weight: 900; } .all-news-grid a { display: block; padding: 12px 0; border-top: 1px solid var(--gray400); font-family: var(--font-headline); font-size: var(--fs-112); font-weight: 900; line-height: 1.25; color: inherit; }
      .people-section { display: grid; grid-template-columns: minmax(0, 1fr) 420px; gap: 40px; align-items: center; } .feature-grid, .question-grid, .pillar-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; } .feature-card, .mini-feature, .pillar-card, .question-card, .note-box, .category-feature, .article-toc, .language-box, .book-affiliate, .travel-affiliate, .related-articles article, .share-buttons a, .social-links a { border: 1px solid var(--gray400); background: var(--paper); color: var(--ink); } .feature-card, .mini-feature, .pillar-card, .question-card { padding: 16px; }
      .category-hero { padding: 48px 0 32px; border-bottom: 1px solid var(--ink); margin: 0 0 32px; } .category-hero h1 { margin-bottom: 16px; font-size: var(--fs-350); line-height: 1.05; } .category-hero .dek { max-width: 760px; color: var(--gray80); font-family: var(--font-meta); font-size: var(--fs-125); font-weight: 400; line-height: 1.55; }
      .article-page { margin: 0; } .article-shell, .article-shell--with-aside { display: grid; grid-template-columns: 220px minmax(0, 740px); gap: 44px; padding: 48px 0 64px; border-bottom: 1px solid var(--gray400); } .article-shell:not(.article-shell--with-aside) { grid-template-columns: minmax(0, 740px); justify-content: center; } .article-aside { position: sticky; top: 24px; align-self: start; } .article-body p, .article-body li { color: #202020; font-family: var(--font-body); font-size: 17px; line-height: 1.85; } .article-body h2 { margin-top: 42px; margin-bottom: 16px; font-size: 28px; line-height: 1.16; } .article-body h2:first-child { margin-top: 0; } .article-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; margin: 0 0 56px; background: var(--gray400); } .article-nav a { padding: 24px; background: var(--paper); font-family: var(--font-meta); font-weight: 900; }
      .site-footer { background: #000000; border-top: 2px solid var(--red100); color: var(--footer-muted); font-family: var(--font-meta); } .footer-inner { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 32px; padding: 40px 20px 32px; } .site-footer h2 { margin: 0 0 12px; color: #ffffff; font-family: var(--font-meta); font-size: var(--fs-087); font-weight: 900; line-height: 1.2; } .site-footer ul { margin: 0; padding: 0; list-style: none; } .site-footer li + li { margin-top: 8px; } .site-footer a { color: #ffffff; font-size: var(--fs-087); line-height: 1.35; } .footer-bottom { display: flex; align-items: baseline; gap: 12px; padding: 18px 20px 28px; border-top: 1px solid #242424; color: var(--footer-muted); font-size: var(--fs-075); } .footer-wordmark { color: #ffffff; font-family: var(--font-headline); font-size: var(--fs-112); font-weight: 900; }
      body.reader-large { font-size: 19px; } body.reader-large .story-text p:not(.kicker), body.reader-large .article-deck, body.reader-large .people-section p, body.reader-large .path-grid p, body.reader-large .field-grid p:not(.kicker):not(.byline), body.reader-large .article-stack p:not(.kicker):not(.byline), body.reader-large .all-news-grid a { font-size: 1.18rem; } body.reader-large .article-body p, body.reader-large .article-body li { font-size: 20px; line-height: 1.95; }
      html.theme-dark body { --ink: #ffffff; --paper: #101010; --gray400: #303030; --gray300: #5f5f5f; --gray80: #d4d4d4; --footer-muted: #d0d0d0; --red100: #ff4b55; --color-paper: #101010; --color-surface: #101010; --color-ink: #ffffff; --color-muted: #d4d4d4; --color-accent: #ff4b55; --color-border: #303030; color: var(--ink); background: var(--paper); } html.theme-dark .masthead, html.theme-dark .news-band, html.theme-dark .path-grid a, html.theme-dark .article-nav a, html.theme-dark .feature-card, html.theme-dark .mini-feature, html.theme-dark .pillar-card, html.theme-dark .question-card, html.theme-dark .note-box, html.theme-dark .category-feature, html.theme-dark .article-toc, html.theme-dark .language-box, html.theme-dark .book-affiliate, html.theme-dark .travel-affiliate, html.theme-dark .related-articles article, html.theme-dark .share-buttons a, html.theme-dark .social-links a { background: var(--paper); border-color: var(--gray400); color: var(--ink); } html.theme-dark .menu-button { color: var(--paper); background: var(--ink); border-color: var(--ink); } html.theme-dark .article-body p, html.theme-dark .article-body li { color: #ffffff; } html.theme-dark figcaption, html.theme-dark .story-text p:not(.kicker), html.theme-dark .article-deck, html.theme-dark .people-section p, html.theme-dark .path-grid p, html.theme-dark .article-stack p:not(.kicker):not(.byline), html.theme-dark .field-grid p:not(.kicker):not(.byline), html.theme-dark .byline, html.theme-dark .post-date, html.theme-dark .article-meta, html.theme-dark .article-aside, html.theme-dark .event-callout { color: #d9d9d9; } html.theme-dark img { filter: brightness(0.92); }
      @media (max-width: 980px) { .lead-grid, .lead-link, .two-column, .article-shell, .article-shell--with-aside, .people-section { grid-template-columns: 1fr; } .right-rail { padding-left: 0; border-left: 0; } .section-heading, .article-aside { position: static; } .path-grid, .field-grid, .all-news-grid, .feature-grid, .question-grid, .pillar-grid { grid-template-columns: 1fr; } .footer-inner { grid-template-columns: repeat(2, minmax(0, 1fr)); } .new-articles-list { grid-template-columns: 1fr; } }
      @media (max-width: 640px) { body { font-size: 16px; } main { padding-right: 20px; padding-left: 20px; } .utility-row { grid-template-columns: 1fr; gap: 8px; padding-right: 12px; padding-left: 12px; text-align: center; } .utility-left, .utility-center, .utility-right { justify-content: center; flex-wrap: wrap; gap: 10px; font-size: 11px; line-height: 1.2; } .language-switcher a, .menu-button { min-height: 26px; padding: 3px 7px; white-space: nowrap; } .theme-controls, .reader-controls { min-height: 26px; } .theme-controls span, .reader-controls span { display: none; } .theme-controls button, .reader-controls button { min-width: 26px; min-height: 22px; padding: 3px 6px; } .logo-row { padding-top: 16px; } .logo-main { font-size: 34px; line-height: 1.08; } .logo-sub { font-size: .625rem; letter-spacing: .06em; } .site-motto::before, .site-motto::after { width: 20px; } .section-nav { justify-content: flex-start; gap: 16px; } .section-nav a { padding-top: 10px; padding-bottom: 10px; font-size: .8125rem; } h1 { font-size: 28px; line-height: var(--lh-110); } h2 { font-size: 28px; } .story-text p:not(.kicker), .article-deck, .people-section p { font-size: var(--fs-100); } .article-stack a, .rail-card a { grid-template-columns: 1fr; } .rail-card img { width: 100%; height: auto; aspect-ratio: 3 / 2; } .article-nav { grid-template-columns: 1fr; } .footer-inner { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body class={'lang-' + locale}>
    <header class="masthead">
      <div class="utility-row">
        <div class="utility-left"><a href="#main-content">Accessibility</a><a href={aboutHref}>About</a></div>
        <div class="utility-center language-switcher" aria-label="Language">{languageLinks.map((link) => <a class:list={[{ active: link.active }]} href={link.href}>{link.label}</a>)}</div>
        <div class="utility-right">
          <div class="theme-controls" role="group" aria-label={controlCopy.modeGroup}><span>{controlCopy.modeLabel}</span><button type="button" data-theme-mode="light" aria-pressed="false">{controlCopy.light}</button><button type="button" data-theme-mode="dark" aria-pressed="false">{controlCopy.dark}</button></div>
          <div class="reader-controls" role="group" aria-label={controlCopy.sizeGroup}><span>{controlCopy.sizeLabel}</span><button type="button" data-reader-size="medium" aria-pressed="false">{controlCopy.medium}</button><button type="button" data-reader-size="large" aria-pressed="false">{controlCopy.large}</button></div>
          <a href={archiveHref}>{searchLabel}</a><a class="menu-button" href={archiveHref}>{sectionsLabel}</a>
        </div>
      </div>
      <div class="logo-row"><a class="gazette-logo" href={homeHref}><span class="logo-main">{SITE.name}</span><span class="logo-sub">{SITE.tagline}</span></a><p class="site-motto">{motto}</p></div>
      <nav class="section-nav" aria-label="Primary sections">{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}</nav>
    </header>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="footer-inner">
        <section><h2>{footerAbout}</h2><ul>{legalLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul></section>
        <section><h2>{footerSections}</h2><ul>{navLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul></section>
        <section><h2>{footerFollow}</h2><ul><li><a href={SITE.substackUrl}>{subscribeLabel}</a></li>{SITE.socialLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul></section>
      </div>
      <p class="footer-bottom"><span class="footer-wordmark">{SITE.name}</span> © {new Date().getFullYear()} {footerText}</p>
    </footer>
    <script>
      (() => {
        const themeKey = 'inside-japanese-history-theme-mode';
        const sizeKey = 'inside-japanese-history-reader-size';
        const hour = new Date().getHours();
        const autoTheme = hour >= 18 || hour < 6 ? 'dark' : 'light';
        const savedTheme = localStorage.getItem(themeKey) || autoTheme;
        const savedSize = localStorage.getItem(sizeKey) || 'medium';
        const setTheme = (mode) => { document.body.classList.toggle('theme-dark', mode === 'dark'); document.documentElement.classList.toggle('theme-dark', mode === 'dark'); document.documentElement.style.colorScheme = mode === 'dark' ? 'dark' : 'light'; document.querySelectorAll('[data-theme-mode]').forEach((button) => { button.setAttribute('aria-pressed', button.dataset.themeMode === mode ? 'true' : 'false'); }); };
        const setSize = (size) => { document.body.classList.toggle('reader-large', size === 'large'); document.querySelectorAll('[data-reader-size]').forEach((button) => { button.setAttribute('aria-pressed', button.dataset.readerSize === size ? 'true' : 'false'); }); };
        document.querySelectorAll('[data-theme-mode]').forEach((button) => { button.addEventListener('click', () => { const mode = button.dataset.themeMode || autoTheme; localStorage.setItem(themeKey, mode); setTheme(mode); }); });
        document.querySelectorAll('[data-reader-size]').forEach((button) => { button.addEventListener('click', () => { const size = button.dataset.readerSize || 'medium'; localStorage.setItem(sizeKey, size); setSize(size); }); });
        setTheme(savedTheme === 'dark' ? 'dark' : 'light'); setSize(savedSize === 'large' ? 'large' : 'medium');
      })();
    </script>
  </body>
</html>
