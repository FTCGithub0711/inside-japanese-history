---
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import ArticleTableOfContents from '../components/ArticleTableOfContents.astro';
import BookAffiliateBox from '../components/BookAffiliateBox.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ShareButtons from '../components/ShareButtons.astro';
import SourceList from '../components/SourceList.astro';
import TravelAffiliateBox from '../components/TravelAffiliateBox.astro';

interface TocItem {
  id: string;
  label: string;
}

interface SourceItem {
  label: string;
  description?: string;
  href?: string;
  type?: string;
}

interface RelatedItem {
  title: string;
  description: string;
  href: string;
  kicker?: string;
}

interface TravelDestination {
  name: string;
  description: string;
  stayHref: string;
  placeHref?: string;
  activityHref?: string;
}

interface BookRecommendation {
  title: string;
  description: string;
  href: string;
  author?: string;
  label?: string;
}

interface TranslationLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  kicker?: string;
  datePublished: string;
  dateModified?: string;
  readingTime?: string;
  category?: string;
  image?: string;
  imageCredit?: string;
  lang?: string;
  toc?: TocItem[];
  sources?: SourceItem[];
  related?: RelatedItem[];
  travelDestinations?: TravelDestination[];
  travelTitle?: string;
  travelIntro?: string;
  bookRecommendations?: BookRecommendation[];
  bookTitle?: string;
  bookIntro?: string;
  translations?: TranslationLink[];
  showNewsletter?: boolean;
}

const {
  title,
  description,
  subtitle,
  kicker = 'Feature',
  datePublished,
  dateModified,
  readingTime,
  category,
  image,
  imageCredit,
  lang = 'en-US',
  toc = [],
  sources = [],
  related = [],
  travelDestinations = [],
  travelTitle,
  travelIntro,
  bookRecommendations = [],
  bookTitle,
  bookIntro,
  translations = [],
  showNewsletter = true,
} = Astro.props;

const displayDate = new Intl.DateTimeFormat(
  lang.startsWith('de') ? 'de-DE' : lang.startsWith('ja') ? 'ja-JP' : 'en-US',
  {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  }
).format(new Date(datePublished));

const travelLang = lang.startsWith('de') ? 'de' : lang.startsWith('ja') ? 'ja' : 'en';
const tocTitle = lang.startsWith('de') ? 'In diesem Artikel' : lang.startsWith('ja') ? 'この記事の内容' : 'In this article';
const hasAside = toc.length > 0 || translations.length > 0;
const homeHref = lang.startsWith('de') ? '/de/' : lang.startsWith('ja') ? '/ja/' : '/';
const homeLabel = lang.startsWith('de') ? 'Startseite' : lang.startsWith('ja') ? 'ホーム' : 'Home';
const articlesLabel = lang.startsWith('de') ? 'Artikel' : lang.startsWith('ja') ? '記事' : 'Articles';
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  lang={lang}
>
  <ArticleSchema
    slot="head"
    headline={title}
    description={description}
    datePublished={datePublished}
    dateModified={dateModified}
    image={image}
    inLanguage={lang}
  />
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: homeLabel, href: homeHref },
      { name: articlesLabel, href: homeHref },
      { name: title, href: Astro.url.pathname },
    ]}
  />

  <article class="article-page">
    <header class={image ? 'article-hero article-hero--with-image' : 'article-hero'}>
      {image && (
        <figure>
          <img src={image} alt="" />
          {imageCredit && <figcaption>{imageCredit}</figcaption>}
        </figure>
      )}
      <div class="article-hero__copy">
        <p class="kicker">{kicker}</p>
        <h1>{title}</h1>
        <p class="dek">{subtitle ?? description}</p>
        <div class="article-meta">
          {category && <span>{category}</span>}
          <span>{displayDate}</span>
          {readingTime && <span>{readingTime}</span>}
        </div>
      </div>
    </header>

    <div class={hasAside ? 'article-shell article-shell--with-aside' : 'article-shell'}>
      {hasAside && (
        <aside class="article-aside">
          <ArticleTableOfContents items={toc} title={tocTitle} />
          {translations.length > 0 && (
            <nav class="language-box" aria-label="Article translations">
              <p>Languages</p>
              {translations.map((translation) => (
                <a href={translation.href}>{translation.label}</a>
              ))}
            </nav>
          )}
          <ShareButtons title={title} />
        </aside>
      )}

      <div class="article-body">
        <slot />

        {travelDestinations.length > 0 && (
          <TravelAffiliateBox
            destinations={travelDestinations}
            title={travelTitle}
            intro={travelIntro}
            lang={travelLang}
          />
        )}

        {bookRecommendations.length > 0 && (
          <BookAffiliateBox
            books={bookRecommendations}
            title={bookTitle}
            intro={bookIntro}
            lang={travelLang}
          />
        )}

        <SourceList sources={sources} />
        <RelatedArticles items={related} />
        {showNewsletter && <NewsletterCTA />}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    margin: 0 calc(50% - min(50vw, var(--wide-width) / 2));
  }

  .article-hero {
    border-bottom: 1px solid var(--color-border);
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr);
    padding: 2.4rem 1.25rem 2rem;
  }

  .article-hero--with-image {
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.75fr);
  }

  .article-hero figure {
    margin: 0;
    order: 2;
  }

  .article-hero img {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    display: block;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .article-hero figcaption {
    color: var(--color-muted);
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.76rem;
    margin-top: 0.4rem;
  }

  .article-hero__copy {
    align-self: end;
  }

  .article-hero h1 {
    max-width: 760px;
  }

  .article-meta {
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.8rem;
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.88rem;
    margin-top: 1rem;
  }

  .article-meta span:not(:last-child)::after {
    color: var(--color-border);
    content: "/";
    margin-left: 0.8rem;
  }

  .article-shell {
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 760px);
    justify-content: center;
    padding: 2rem 1.25rem 4rem;
  }

  .article-shell--with-aside {
    align-items: start;
    grid-template-columns: minmax(180px, 250px) minmax(0, 760px);
  }

  .article-aside {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 1.25rem;
  }

  .language-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    display: grid;
    gap: 0.4rem;
    padding: 1rem 1.1rem;
  }

  .language-box p {
    color: var(--color-accent);
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.76rem;
    font-weight: 800;
    margin: 0;
    text-transform: uppercase;
  }

  .language-box a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .language-box a:hover {
    color: var(--color-accent);
  }

  .article-body :global(h2) {
    scroll-margin-top: 1.2rem;
  }

  .article-body :global(.article-callout) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-gold);
    border-radius: 8px;
    margin: 1.7rem 0;
    padding: 1rem 1.1rem;
  }

  .article-body :global(.article-callout p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 860px) {
    .article-hero--with-image,
    .article-shell--with-aside {
      grid-template-columns: 1fr;
    }

    .article-hero figure {
      order: 0;
    }

    .article-aside {
      position: static;
    }
  }
</style>
