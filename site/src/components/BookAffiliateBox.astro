---
import AffiliateDisclosure from './AffiliateDisclosure.astro';

interface BookRecommendation {
  title: string;
  description: string;
  href: string;
  author?: string;
  label?: string;
}

interface Props {
  title?: string;
  intro?: string;
  books: BookRecommendation[];
  lang?: 'en' | 'de' | 'ja';
}

const {
  title,
  intro,
  books,
  lang = 'en',
} = Astro.props;

const copy = lang === 'de'
  ? {
      label: 'Books',
      title: title ?? 'Buecher zu diesem Thema',
      intro:
        intro ??
        'Diese Empfehlungen passen zum Thema des Artikels und werden erst nach der Quellenpruefung gesetzt.',
      action: 'Buch ansehen',
    }
  : lang === 'ja'
    ? {
        label: 'Books',
        title: title ?? 'このテーマに関連する本',
        intro:
          intro ??
          '記事内容に直接関係する本だけを、確認後にここへ入れます。',
        action: '本を見る',
      }
  : {
      label: 'Books',
      title: title ?? 'Books connected to this article',
      intro:
        intro ??
        'These recommendations should be tied to the article topic and replaced with specific books during editing.',
      action: 'View book',
    };
---

{books.length > 0 && (
  <aside class="book-affiliate" aria-label={copy.title}>
    <div class="book-affiliate__header">
      <p class="label">{copy.label}</p>
      <h2>{copy.title}</h2>
      <p>{copy.intro}</p>
    </div>

    <div class="book-affiliate__grid">
      {books.map((book) => (
        <article>
          <p class="book-affiliate__type">{book.label ?? copy.label}</p>
          <h3>{book.title}</h3>
          {book.author && <p class="book-affiliate__author">{book.author}</p>}
          <p>{book.description}</p>
          <a href={book.href} target="_blank" rel="sponsored noopener noreferrer">
            {copy.action}
          </a>
        </article>
      ))}
    </div>

    <AffiliateDisclosure lang={lang} />
  </aside>
)}

<style>
  .book-affiliate {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin: 2.2rem 0;
    padding: 1.1rem;
  }

  .book-affiliate__header {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
  }

  .book-affiliate .label,
  .book-affiliate__type {
    color: var(--color-accent);
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.74rem;
    font-weight: 800;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .book-affiliate h2 {
    font-size: 1.25rem;
    margin: 0 0 0.35rem;
  }

  .book-affiliate h3 {
    font-size: 1.04rem;
    margin: 0 0 0.25rem;
  }

  .book-affiliate p {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .book-affiliate__grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .book-affiliate article {
    border: 1px solid var(--color-border);
    border-radius: 7px;
    padding: 0.9rem;
  }

  .book-affiliate__author {
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.85rem;
    margin-bottom: 0.45rem;
  }

  .book-affiliate a {
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    color: var(--color-accent);
    display: inline-block;
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 750;
    margin-top: 0.8rem;
    padding: 0.45rem 0.6rem;
    text-decoration: none;
  }

  .book-affiliate a:hover {
    background: var(--color-accent);
    color: white;
  }
</style>
