---
import { SITE } from '../consts';

interface Props {
  heading?: string;
}

const { heading = 'Follow the project' } = Astro.props;
const links = SITE.socialLinks;
---

{links.length > 0 && (
  <section class="social-links" aria-labelledby="social-links-heading">
    <h2 id="social-links-heading">{heading}</h2>
    <div>
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </section>
)}

<style>
  .social-links {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
    margin: 2.5rem 0;
  }

  .social-links h2 {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
  }

  .social-links div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .social-links a {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-ink);
    padding: 0.5rem 0.8rem;
    text-decoration: none;
    background: var(--color-surface);
  }

  .social-links a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
