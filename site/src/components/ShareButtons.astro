---
import { SITE } from '../consts';

interface Props {
  title: string;
  url?: string;
  heading?: string;
}

const {
  title,
  url = new URL(Astro.url.pathname, Astro.site).toString(),
  heading = 'Share this article',
} = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(`${title} — ${SITE.name}`);
const links = [
  {
    label: 'X',
    href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  },
  {
    label: 'Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  },
  {
    label: 'Email',
    href: `mailto:?subject=${encodedTitle}&body=${encodedUrl}`,
  },
];
---

<aside class="share-buttons" aria-label={heading}>
  <p>{heading}</p>
  <div>
    {links.map((link) => (
      <a href={link.href} target={link.label === 'Email' ? undefined : '_blank'} rel="noopener noreferrer">
        {link.label}
      </a>
    ))}
  </div>
</aside>

<style>
  .share-buttons {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }

  .share-buttons p {
    color: var(--color-muted);
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 750;
    margin: 0 0 0.65rem;
  }

  .share-buttons div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .share-buttons a {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-ink);
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.45rem 0.7rem;
    text-decoration: none;
  }

  .share-buttons a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
